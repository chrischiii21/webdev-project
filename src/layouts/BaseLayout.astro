---
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import "../styles/global.css";

// Define the Props so you can pass a unique description from each page
const {
	title = "Web Dev Final",
	description = "This contains the final webdev final project that buckets all the templates created by the company.",
} = Astro.props;
---

<html lang="en">
	<head>
		<!-- CRITICAL: Preconnect to Google Fonts FIRST - before any other requests -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<meta charset="utf-8" />
		<link rel="icon" type="image/avif" href="/images/logo.avif" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />

		<!-- CRITICAL: Preload primary font with font-display: swap to prevent FOIT/FOUT -->
		<link
			rel="preload"
			href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap"
			as="style"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap"
			rel="stylesheet"
		/>

		<!-- CRITICAL: Inline critical CSS for LCP element to bypass stylesheet network request -->
		<style>
			/* Critical path CSS for Hero LCP text */
			body {
				font-family: "Poppins", ui-sans-serif, system-ui, sans-serif;
				margin: 0;
				padding: 0;
			}

			section {
				display: block;
			}

			h1,
			p {
				margin: 0;
				padding: 0;
			}

			/* Hero section critical styles - LCP element */
			.hero-lcp {
				color: white;
				font-family: "Poppins", ui-sans-serif, system-ui, sans-serif;
				font-weight: 700;
				line-height: 1.2;
				letter-spacing: -0.02em;
			}

			.hero-description {
				color: white;
				font-family: "Poppins", ui-sans-serif, system-ui, sans-serif;
				font-weight: 400;
				line-height: 1.6;
				font-size: 1rem;
			}

			/* Prevent layout shift */
			html {
				scroll-behavior: auto;
			}

			* {
				box-sizing: border-box;
			}
		</style>

		<title>{title}</title>
	</head>
	<body
		class="min-h-screen flex flex-col font-primary"
		style="font-family: 'Poppins', ui-sans-serif, system-ui, sans-serif;"
	>
		<Navbar />
		<main class="flex-1">
			<slot />
		</main>
		<Footer />
		<script src="/src/scripts/scroll-animate.js"></script>
	</body>
</html>
