---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Sitemap | BuildPro"
    description="Browse the complete sitemap of BuildPro's website. Find links to all pages and services."
>
    <!-- Hero Section -->
    <section class="py-20 bg-linear-to-br from-[#0a1931] to-[#1a2a4a]">
        <div class="max-w-4xl mx-auto px-8">
            <h1 class="text-5xl font-bold text-white mb-4">Sitemap</h1>
            <p class="text-lg text-white/80">
                Navigate through all pages and sections of BuildPro
            </p>
        </div>
    </section>

    <!-- Content Section -->
    <section class="py-20 bg-white">
        <div class="max-w-4xl mx-auto px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <!-- Main Pages -->
                <div>
                    <h2 class="text-2xl font-bold text-[#0A1931] mb-6">
                        Main Pages
                    </h2>
                    <ul class="space-y-3">
                        <li>
                            <a
                                href="/"
                                class="text-[#F48C06] hover:text-[#ff6b35] transition-colors"
                            >
                                Home
                            </a>
                        </li>
                        <li>
                            <a
                                href="/about"
                                class="text-[#F48C06] hover:text-[#ff6b35] transition-colors"
                            >
                                About Us
                            </a>
                        </li>
                        <li>
                            <a
                                href="/what-we-do"
                                class="text-[#F48C06] hover:text-[#ff6b35] transition-colors"
                            >
                                What We Do
                            </a>
                        </li>
                        <li>
                            <a
                                href="/our-work"
                                class="text-[#F48C06] hover:text-[#ff6b35] transition-colors"
                            >
                                Our Work
                            </a>
                        </li>
                        <li>
                            <a
                                href="/reviews"
                                class="text-[#F48C06] hover:text-[#ff6b35] transition-colors"
                            >
                                Reviews
                            </a>
                        </li>
                        <li>
                            <a
                                href="/contact"
                                class="text-[#F48C06] hover:text-[#ff6b35] transition-colors"
                            >
                                Contact Us
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Services -->
                <div>
                    <h2 class="text-2xl font-bold text-[#0A1931] mb-6">
                        Services
                    </h2>
                    <ul class="space-y-3">
                        <li>
                            <a
                                href="/trades-we-serve"
                                class="text-[#F48C06] hover:text-[#ff6b35] transition-colors"
                            >
                                Trades We Serve
                            </a>
                        </li>
                        <li>
                            <a
                                href="/trades-we-serve/hvac"
                                class="text-[#F48C06] hover:text-[#ff6b35] transition-colors"
                            >
                                HVAC Services
                            </a>
                        </li>
                        <li>
                            <a
                                href="/trades-we-serve/plumbing"
                                class="text-[#F48C06] hover:text-[#ff6b35] transition-colors"
                            >
                                Plumbing Services
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Legal & Information -->
                <div>
                    <h2 class="text-2xl font-bold text-[#0A1931] mb-6">
                        Legal & Information
                    </h2>
                    <ul class="space-y-3">
                        <li>
                            <a
                                href="/privacy"
                                class="text-[#F48C06] hover:text-[#ff6b35] transition-colors"
                            >
                                Privacy Policy
                            </a>
                        </li>
                        <li>
                            <a
                                href="/terms"
                                class="text-[#F48C06] hover:text-[#ff6b35] transition-colors"
                            >
                                Terms of Service
                            </a>
                        </li>
                        <li>
                            <a
                                href="/sitemap"
                                class="text-[#F48C06] hover:text-[#ff6b35] transition-colors"
                            >
                                Sitemap
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Contact Information -->
                <div>
                    <h2 class="text-2xl font-bold text-[#0A1931] mb-6">
                        Contact Information
                    </h2>
                    <ul class="space-y-3 text-[#0A1931]">
                        <li>
                            <p class="font-semibold">Phone</p>
                            <a
                                href="tel:+15551234567"
                                class="text-[#F48C06] hover:text-[#ff6b35] transition-colors"
                            >
                                (555) 123-4567
                            </a>
                        </li>
                        <li>
                            <p class="font-semibold">Email</p>
                            <a
                                href="mailto:info@buildpro.com"
                                class="text-[#F48C06] hover:text-[#ff6b35] transition-colors"
                            >
                                info@buildpro.com
                            </a>
                        </li>
                        <li>
                            <p class="font-semibold">Address</p>
                            <p class="text-[#0A1931]">
                                123 Main Street, City, State 12345
                            </p>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Additional Info -->
            <div class="mt-12 p-8 bg-[#f5f5f5] rounded-lg">
                <h3 class="text-xl font-bold text-[#0A1931] mb-4">
                    About This Sitemap
                </h3>
                <p class="text-[#0A1931] leading-relaxed">
                    This sitemap provides a complete overview of all pages and
                    sections available on the BuildPro website. Use this page to
                    navigate to any section of our site or to find specific
                    information about our services. For a more detailed XML
                    sitemap for search engines, please visit <a
                        href="/sitemap.xml"
                        class="text-[#F48C06] hover:text-[#ff6b35]"
                        >sitemap.xml</a
                    >.
                </p>
            </div>
        </div>
    </section>
</BaseLayout>
