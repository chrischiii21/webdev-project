---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Terms of Service | BuildPro"
    description="Read BuildPro's Terms of Service. Understand the rules and conditions for using our website and services."
>
    <!-- Hero Section -->
    <section class="py-20 bg-linear-to-br from-[#0a1931] to-[#1a2a4a]">
        <div class="max-w-4xl mx-auto px-8">
            <h1 class="text-5xl font-bold text-white mb-4">Terms of Service</h1>
            <p class="text-lg text-white/80">Last updated: January 2024</p>
        </div>
    </section>

    <!-- Content Section -->
    <section class="py-20 bg-white">
        <div class="max-w-4xl mx-auto px-8">
            <div class="prose prose-lg max-w-none">
                <h2 class="text-3xl font-bold text-[#0A1931] mb-6">
                    Introduction
                </h2>
                <p class="text-[#0A1931] mb-8 leading-relaxed">
                    These Terms of Service ("Terms") govern your use of the
                    BuildPro website and services. By accessing and using our
                    website, you accept and agree to be bound by and comply with
                    these Terms and our Privacy Policy.
