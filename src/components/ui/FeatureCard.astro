---
interface Props {
    id: string;
    title: string;
    description: string;
    accentColor?: string;
    variant?: "trade" | "pillar" | "value";
    iconPath?: string;
}

const {
    id,
    title,
    description,
    accentColor = "#0A1931",
    variant = "trade",
    iconPath,
} = Astro.props;

// Icon mapping for different feature titles
const getIcon = (title: string) => {
    const icons: Record<string, string> = {
        "Seasonal Demand Visibility":
            '<path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/>',
        "Maintenance Plan Promotions":
            '<path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/>',
        "Emergency Service Availability":
            '<path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56-.35-.12-.74-.03-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/>',
        "Technician Credentials Display":
            '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/><path d="M12 7c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>',
        "Service Area Expansion":
            '<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>',
        "Energy Efficiency Focus":
            '<path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.95-2.3c.48.17.98.3 1.34.3C19 20 22 3 22 3c-1 0-17 2-5 5z"/><path d="M3.5 12.5c0 0 2 2 5.5 2s5.5-2 5.5-2-2-2-5.5-2-5.5 2-5.5 2z"/>',
        "Emergency Service Visibility":
            '<path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/>',
        "Online Appointment Booking":
            '<path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/><path d="M12.5 7H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>',
        "Local SEO & Service Areas":
            '<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>',
        "Customer Reviews Integration":
            '<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>',
        "Mobile-First Design":
            '<path d="M17 2H7c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM7 4h10v14H7V4z"/><circle cx="12" cy="20" r="1"/>',
        "Service Portfolio Showcase":
            '<path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>',
        "Template Architecture":
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2m6-2v2M9 3H7a2 2 0 00-2 2v2m16-4v2m0 6H3m0 6h18v2a2 2 0 01-2 2H5a2 2 0 01-2-2v-2zm0-6V9a2 2 0 012-2h14a2 2 0 012 2v6M9 19v2m6-2v2"/>',
        "Conversion Optimization":
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>',
        "Local SEO Integration":
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>',
        "Results-Driven":
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>',
        "Client-Focused":
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>',
        "Fast & Efficient":
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>',
        "Reliable Support":
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>',
    };
    return (
        iconPath ||
        icons[title] ||
        '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>'
    );
};

// Variant-specific styles
const variantStyles = {
    trade: {
        container:
            "relative bg-white rounded-3xl p-8 border border-[#99B0BB]/10 shadow-lg hover:shadow-2xl transition-all duration-500 hover:scale-105 overflow-hidden",
        iconContainer:
            "w-14 h-14 rounded-2xl flex items-center justify-center shadow-xl transition-all duration-300",
        iconSize: "w-7 h-7",
        title: "text-xl font-bold text-[#0A1931] mb-3 group-hover:text-[#F48C06] transition-colors duration-300",
        description: "text-base text-[#0A1931] leading-relaxed",
    },
    pillar: {
        container:
            "relative bg-white rounded-2xl p-6 border border-gray-100 shadow-md hover:shadow-lg transition-all duration-300",
        iconContainer:
            "w-16 h-16 rounded-lg flex items-center justify-center transition-all duration-300 group-hover:scale-110",
        iconSize: "w-8 h-8",
        title: "text-lg font-bold text-[#0A1931] mb-2",
        description: "text-sm text-[#0A1931] leading-relaxed",
    },
    value: {
        container:
            "relative bg-white/10 backdrop-blur rounded-2xl p-6 border border-white/20 hover:bg-white/15 transition-all duration-300",
        iconContainer:
            "w-16 h-16 rounded-full bg-gradient-to-br from-[#F48C06] to-[#ff6b35] flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300",
        iconSize: "w-8 h-8",
        title: "text-lg font-bold text-white mb-2",
        description: "text-sm text-white/90 leading-relaxed",
    },
};

const styles = variantStyles[variant];
---

<div {id} class="group relative flex">
    <div class={styles.container}>
        {
            variant === "trade" && (
                <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-[#F48C06]/10 to-transparent rounded-bl-full" />
            )
        }

        <!-- Icon -->
        <div class={`relative ${variant === "value" ? "mb-0" : "mb-6"}`}>
            <div
                class={styles.iconContainer}
                style={variant === "trade"
                    ? `background: linear-gradient(135deg, ${accentColor}, ${accentColor}DD);`
                    : variant === "pillar"
                      ? "background-color: rgba(244, 140, 6, 0.1);"
                      : ""}
            >
                <svg
                    class={`${styles.iconSize} ${variant === "pillar" ? "text-[#F48C06]" : variant === "value" ? "text-white" : "text-white"}`}
                    fill={variant === "trade" ? "currentColor" : "none"}
                    stroke={variant !== "trade" ? "currentColor" : "none"}
                    viewBox="0 0 24 24"
                    set:html={getIcon(title)}
                />
            </div>
        </div>

        <!-- Content -->
        <div class="relative">
            <h4 class={styles.title}>
                {title}
            </h4>
            <p class={styles.description}>
                {description}
            </p>
        </div>
    </div>
</div>
