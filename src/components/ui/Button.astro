---
interface Props {
  variant?: "primary" | "secondary" | "ghost" | "danger";
  size?: "sm" | "md" | "lg";
  customPadding?: string;
  customTextSize?: string;
  href?: string;
  disabled?: boolean;
  fullWidth?: boolean;
  class?: string;
  ariaLabel?: string;
  type?: "button" | "submit" | "reset";
}

const {
  variant = "primary",
  size = "md",
  customPadding,
  customTextSize,
  href,
  disabled = false,
  fullWidth = false,
  class: className = "",
  ariaLabel,
  type = "button",
} = Astro.props;

const baseClasses = `
  inline-flex items-center justify-center gap-2 font-primary font-semibold
  border-none rounded-xl cursor-pointer select-none
  focus:outline-none disabled:opacity-40 disabled:cursor-not-allowed uppercase tracking-wider
  relative overflow-hidden
`;

const variantClasses = {
  primary:
    "text-white btn-swipe",
  secondary:
    "text-white btn-swipe",
  ghost:
    "border-2 border-[#99B0BB] text-white btn-swipe",
  danger:
    "text-white btn-swipe",
};

const sizeClasses = {
  sm: "px-6 py-3 text-sm",
  md: "px-8 py-4 text-base",
  lg: "px-10 py-5 text-lg",
};

// Use custom sizes if provided, otherwise use preset sizes
const paddingClass =
  customPadding || sizeClasses[size].split(" ").slice(0, 2).join(" ");
const textSizeClass = customTextSize || sizeClasses[size].split(" ")[2];

const widthClass = fullWidth ? "w-full" : "";

const allClasses = [
  baseClasses,
  variantClasses[variant],
  paddingClass,
  textSizeClass,
  widthClass,
  className,
]
  .join(" ")
  .replace(/\s+/g, " ")
  .trim();

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  type={!href ? type : undefined}
  disabled={!href ? disabled : undefined}
  aria-disabled={disabled}
  aria-label={ariaLabel}
  class={allClasses}
>
  <span class="btn-content">
    <slot />
  </span>
</Tag>

<style>
  .btn-swipe {
    background: linear-gradient(to right, var(--helios-orange), #ff6b35);
    position: relative;
    transition: all 0.3s ease;
    color: #ffffff;
  }

  .btn-swipe::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right, var(--midnight-navy), var(--steel-blue));
    transition: left 0.3s ease;
    border-radius: inherit;
    z-index: 0;
  }

  .btn-swipe:hover::before {
    left: 0;
  }

  .btn-content {
    position: relative;
    z-index: 10;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
  }

  .btn-swipe:hover .btn-content {
    color: #ffffff;
  }

  .btn-content * {
    color: inherit;
  }
</style>
