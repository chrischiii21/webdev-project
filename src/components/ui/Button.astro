---
interface Props {
  variant?: "primary" | "secondary" | "ghost" | "danger";
  size?: "sm" | "md" | "lg";
  customPadding?: string;
  customTextSize?: string;
  href?: string;
  disabled?: boolean;
  fullWidth?: boolean;
  class?: string;
  ariaLabel?: string;
  type?: "button" | "submit" | "reset";
  hoverAccent?: string;
  theme?: "light" | "dark";
  scrollAdaptive?: boolean;
}

const {
  variant = "primary",
  size = "md",
  customPadding,
  customTextSize,
  href,
  disabled = false,
  fullWidth = false,
  class: className = "",
  ariaLabel,
  type = "button",
  hoverAccent,
  theme = "dark",
  scrollAdaptive = false,
} = Astro.props;

const baseClasses = `
  inline-flex items-center justify-center gap-2 font-primary font-semibold
  border-none rounded-xl cursor-pointer select-none
  focus:outline-none disabled:opacity-40 disabled:cursor-not-allowed uppercase tracking-wider
  relative
`;

const variantClasses = {
  primary:
    "text-white btn-swipe",
  secondary:
    "text-white btn-swipe",
  ghost:
    "border-2 border-[#99B0BB] text-white btn-swipe",
  danger:
    "text-white btn-swipe",
};

const sizeClasses = {
  sm: "px-6 py-3 text-sm",
  md: "px-8 py-4 text-base",
  lg: "px-10 py-5 text-lg",
};

// Use custom sizes if provided, otherwise use preset sizes
const paddingClass =
  customPadding || sizeClasses[size].split(" ").slice(0, 2).join(" ");
const textSizeClass = customTextSize || sizeClasses[size].split(" ")[2];

const widthClass = fullWidth ? "w-full" : "";

const allClasses = [
  baseClasses,
  variantClasses[variant],
  paddingClass,
  textSizeClass,
  widthClass,
  className,
]
  .join(" ")
  .replace(/\s+/g, " ")
  .trim();

const Tag = href ? "a" : "button";

// Background color themes for hover effects
const hoverThemes = {
  light: "linear-gradient(to right, #ffffff, #f8f9fa)",
  dark: "linear-gradient(to right, var(--midnight-navy), var(--steel-blue))",
};

const currentHoverBackground = hoverThemes[theme];
---

<Tag
  href={href}
  type={!href ? type : undefined}
  disabled={!href ? disabled : undefined}
  aria-disabled={disabled}
  aria-label={ariaLabel}
  class={`${allClasses} ${theme === 'light' ? 'btn-light-theme' : ''} ${scrollAdaptive ? 'btn-scroll-adaptive' : ''}`}
  style={scrollAdaptive ? 
    (hoverAccent ? `--hover-accent: ${hoverAccent}` : undefined) : 
    (hoverAccent ? `--hover-accent: ${hoverAccent}; --hover-background: ${currentHoverBackground}` : `--hover-background: ${currentHoverBackground}`)
  }
>
  <span class="btn-content">
    <slot />
  </span>
</Tag>

<style>
  .btn-swipe {
    background: linear-gradient(to right, var(--helios-orange), #ff6b35);
    position: relative;
    transition: all 0.3s ease;
    color: #ffffff;
    overflow: hidden;
  }

  .btn-swipe::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: var(--hover-background, linear-gradient(to right, var(--midnight-navy), var(--steel-blue)));
    transition: left 0.3s ease;
    border-radius: inherit;
    z-index: 0;
    overflow: hidden;
  }

  /* Scroll adaptive buttons override the default hover background */
  .btn-scroll-adaptive::before {
    background: #ffffff !important;
  }

  .btn-swipe:hover::before {
    left: 0;
  }

  .btn-content {
    position: relative;
    z-index: 10;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-swipe:hover .btn-content {
    color: var(--helios-orange);
  }

  .btn-light-theme:hover .btn-content {
    color: var(--helios-orange);
  }

  .btn-content * {
    color: inherit;
  }

  /* Scroll adaptive button styles */
  /* Not scrolled: swipe reveals white, text becomes helios-orange */
  .btn-scroll-adaptive::before {
    background: #ffffff !important;
  }

  .btn-scroll-adaptive:hover .btn-content {
    color: var(--helios-orange) !important;
  }

  /* Scrolled: swipe reveals midnight-navy, text stays helios-orange */
  .btn-scroll-adaptive.is-scrolled::before {
    background: var(--midnight-navy) !important;
  }

  .btn-scroll-adaptive.is-scrolled:hover .btn-content {
    color: var(--helios-orange) !important;
  }
</style>

<script>
  // Handle scroll adaptive buttons
  document.addEventListener('DOMContentLoaded', () => {
    const scrollAdaptiveButtons = document.querySelectorAll('.btn-scroll-adaptive');

    if (scrollAdaptiveButtons.length > 0) {
      const navbar = document.querySelector('nav');

      if (navbar) {
        const observer = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
              const isScrolled = navbar.classList.contains('navbar-scrolled');

              scrollAdaptiveButtons.forEach((button) => {
                // Toggle is-scrolled directly on the button itself
                button.classList.toggle('is-scrolled', isScrolled);
                // Keep btn-light-theme in sync so the base text color stays correct
                button.classList.toggle('btn-light-theme', isScrolled);
              });
            }
          });
        });

        observer.observe(navbar, {
          attributes: true,
          attributeFilter: ['class'],
        });
      }
    }
  });
</script>
