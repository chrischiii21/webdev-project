---
interface Props {
  variant?: "primary" | "secondary" | "ghost" | "danger";
  size?: "sm" | "md" | "lg";
  customPadding?: string;
  customTextSize?: string;
  href?: string;
  disabled?: boolean;
  fullWidth?: boolean;
  class?: string;
  ariaLabel?: string;
  type?: "button" | "submit" | "reset";
  hoverAccent?: string;
  theme?: "light" | "dark";
  scrollAdaptive?: boolean;
  accentColor?: string; // Directly pass any CSS color
  colorScheme?: "orange" | "navy"; // "orange" → fills midnight-navy, "navy" → fills helios-orange
}

const {
  variant = "primary",
  size = "md",
  customPadding,
  customTextSize,
  href,
  disabled = false,
  fullWidth = false,
  class: className = "",
  ariaLabel,
  type = "button",
  hoverAccent,
  theme = "dark",
  scrollAdaptive = false,
  accentColor,
  colorScheme,
} = Astro.props;

// colorScheme picks the opposite: if the card's hoverColor is orange, button fills navy, and vice versa
const colorSchemeMap = {
  orange: "var(--midnight-navy)", // card is orange → button is navy
  navy: "var(--helios-orange)",   // card is navy  → button is orange
};

const resolvedAccent = accentColor ?? (colorScheme ? colorSchemeMap[colorScheme] : undefined);

const baseClasses = `
  inline-flex items-center justify-center gap-2 font-primary font-semibold
  border-none rounded-xl cursor-pointer select-none
  focus:outline-none disabled:opacity-40 disabled:cursor-not-allowed uppercase tracking-wider
  relative
`;

const variantClasses = {
  primary: "text-white btn-swipe",
  secondary: "text-white btn-swipe",
  ghost: "border-2 border-[#99B0BB] text-white btn-swipe",
  danger: "text-white btn-swipe",
};

const sizeClasses = {
  sm: "px-6 py-3 text-sm",
  md: "px-8 py-4 text-base",
  lg: "px-10 py-5 text-lg",
};

const paddingClass =
  customPadding || sizeClasses[size].split(" ").slice(0, 2).join(" ");
const textSizeClass = customTextSize || sizeClasses[size].split(" ")[2];

const widthClass = fullWidth ? "w-full" : "";

const allClasses = [
  baseClasses,
  variantClasses[variant],
  paddingClass,
  textSizeClass,
  widthClass,
  className,
]
  .join(" ")
  .replace(/\s+/g, " ")
  .trim();

const Tag = href ? "a" : "button";

const hoverThemes = {
  light: "linear-gradient(to right, #ffffff, #f8f9fa)",
  dark: "linear-gradient(to right, var(--midnight-navy), var(--steel-blue))",
};

const currentHoverBackground = hoverThemes[theme];
---

<Tag
  href={href}
  type={!href ? type : undefined}
  disabled={!href ? disabled : undefined}
  aria-disabled={disabled}
  aria-label={ariaLabel}
  class={`${allClasses} ${theme === 'light' ? 'btn-light-theme' : ''} ${scrollAdaptive ? 'btn-scroll-adaptive' : ''}`}
  style={[
    resolvedAccent ? `--btn-accent: ${resolvedAccent}` : null,
    scrollAdaptive
      ? (hoverAccent ? `--hover-accent: ${hoverAccent}` : null)
      : `--hover-background: ${currentHoverBackground}${hoverAccent ? `; --hover-accent: ${hoverAccent}` : ''}`,
  ].filter(Boolean).join('; ') || undefined}
>
  <span class="btn-content">
    <slot />
  </span>
</Tag>

<style>
  .btn-swipe {
    /* Uses --btn-accent if provided, otherwise falls back to helios-orange */
    background: linear-gradient(
      to right,
      var(--btn-accent, var(--helios-orange)),
      var(--btn-accent, #ff6b35)
    );
    position: relative;
    transition: all 0.3s ease;
    color: #ffffff;
    overflow: hidden;
  }

  .btn-swipe::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: var(--hover-background, linear-gradient(to right, var(--midnight-navy), var(--steel-blue)));
    transition: left 0.3s ease;
    border-radius: inherit;
    z-index: 0;
    overflow: hidden;
  }

  .btn-scroll-adaptive::before {
    background: #ffffff !important;
  }

  .btn-swipe:hover::before {
    left: 0;
  }

  .btn-content {
    position: relative;
    z-index: 10;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-swipe:hover .btn-content {
    color: var(--helios-orange);
  }

  .btn-light-theme:hover .btn-content {
    color: var(--helios-orange);
  }

  .btn-content * {
    color: inherit;
  }

  .btn-scroll-adaptive:hover .btn-content {
    color: var(--helios-orange) !important;
  }

  .btn-scroll-adaptive.is-scrolled::before {
    background: var(--midnight-navy) !important;
  }

  .btn-scroll-adaptive.is-scrolled:hover .btn-content {
    color: var(--helios-orange) !important;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const scrollAdaptiveButtons = document.querySelectorAll('.btn-scroll-adaptive');

    if (scrollAdaptiveButtons.length > 0) {
      const navbar = document.querySelector('nav');

      if (navbar) {
        const observer = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
              const isScrolled = navbar.classList.contains('navbar-scrolled');

              scrollAdaptiveButtons.forEach((button) => {
                button.classList.toggle('is-scrolled', isScrolled);
                button.classList.toggle('btn-light-theme', isScrolled);
              });
            }
          });
        });

        observer.observe(navbar, {
          attributes: true,
          attributeFilter: ['class'],
        });
      }
    }
  });
</script>