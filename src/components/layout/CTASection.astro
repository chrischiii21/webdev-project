---
// CTA Section Component - Professional call-to-action with form
// Placed above footer on all pages
import Button from "../ui/Button.astro";
import FormInput from "../ui/FormInput.astro";

export interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  eyebrow?: string;
}

const {
  title = "Ready to Transform Your Business?",
  subtitle = "Get started today and see how we can help you grow",
  description = "Our team of experts is ready to help you build a powerful online presence that drives results.",
  eyebrow = "LET'S GET STARTED",
} = Astro.props;
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto">
    <div
      class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start px-8"
    >
      <!-- Left Content -->
      <div class="space-y-4">
        <!-- Eyebrow -->
        <div>
          <span
            id="cta-eyebrow"
            class="font-semibold tracking-widest uppercase"
            style="color: var(--helios-orange); font-size: 16px;"
          >
            {eyebrow}
          </span>
        </div>

        <!-- Main Heading -->
        <div class="space-y-4">
          <h2
            id="cta-title"
            class="text-4xl md:text-5xl font-bold text-[#0A1931] leading-tight"
          >
            {title}
          </h2>
          <p id="cta-desc" class="text-[#0A1931] leading-relaxed max-w-xl" style="font-size: 22px;">
            Our team of experts is ready to help you build a powerful online
            presence that drives real measurable results for your business.
          </p>
        </div>

        <!-- Features List -->
        <div class="space-y-6 pt-2">
          <div id="cta-feature-1" class="flex items-start gap-4">
            <div
              class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center"
              style="background-color: var(--helios-orange);"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-[#0A1931] mb-1">Expert Team</h3>
              <p class="text-base text-[#0A1931]">
                Experienced professionals dedicated to your success
              </p>
            </div>
          </div>

          <div id="cta-feature-2" class="flex items-start gap-4">
            <div
              class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center"
              style="background-color: var(--helios-orange);"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-[#0A1931] mb-1">Proven Results</h3>
              <p class="text-base text-[#0A1931]">
                Trusted by 2,500+ contractors and service providers
              </p>
            </div>
          </div>

          <div id="cta-feature-3" class="flex items-start gap-4">
            <div
              class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center"
              style="background-color: var(--helios-orange);"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-[#0A1931] mb-1">24/7 Support</h3>
              <p class="text-base text-[#0A1931]">
                Always here to help you succeed
              </p>
            </div>
          </div>

          <div id="cta-feature-4" class="flex items-start gap-4">
            <div
              class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center"
              style="background-color: var(--helios-orange);"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-[#0A1931] mb-1">
                Industry Expertise
              </h3>
              <p class="text-base text-[#0A1931]">
                Specialized knowledge in contractor and trades marketing
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right CTA Card -->
      <div
        id="cta-form-card"
        class="bg-linear-to-br from-[#0A1931] to-[#1a2a4a] rounded-2xl p-8 md:p-10 shadow-xl"
      >
        <h3 class="text-2xl md:text-3xl font-bold text-white mb-2">
          Book a free consultation
        </h3>
        <p class="text-[#99B0BB] mb-8 text-base">
          Let's discuss how we can help grow your business
        </p>

        <!-- Contact Form -->
        <form class="space-y-4">
          <FormInput
            type="text"
            name="name"
            placeholder="Your Name"
            variant="light"
            required
          />

          <FormInput
            type="email"
            name="email"
            placeholder="Your Email"
            variant="light"
            required
          />

          <FormInput
            type="tel"
            name="phone"
            placeholder="Your Phone Number"
            variant="light"
            required
          />

          <FormInput
            type="select"
            name="trade"
            placeholder="Select Your Trade"
            options={[
              { value: "hvac", label: "HVAC" },
              { value: "plumbing", label: "Plumbing" },
              { value: "other", label: "Other" },
            ]}
            variant="light"
            required
          />

          <FormInput
            type="textarea"
            name="message"
            placeholder="Tell us about your project"
            rows={4}
            variant="light"
            required
          />

          <Button variant="primary" fullWidth theme="light">
            Get Your Free Consultation
          </Button>
        </form>

        <!-- Trust Badge -->
        <div class="mt-6 pt-6 border-t border-white/10">
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
            <div class="flex items-center gap-2">
              <svg
                class="w-4 h-4 text-[#F48C06] shrink-0"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              <span class="text-sm text-white/80 font-medium whitespace-nowrap"
                >No credit card required</span
              >
            </div>
            <div class="flex items-center gap-2">
              <svg
                class="w-4 h-4 text-[#F48C06] shrink-0"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              <span class="text-sm text-white/80 font-medium whitespace-nowrap"
                >Free estimate</span
              >
            </div>
            <div class="flex items-center gap-2">
              <svg
                class="w-4 h-4 text-[#F48C06] shrink-0"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              <span class="text-sm text-white/80 font-medium whitespace-nowrap"
                >No obligation</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  input::placeholder,
  textarea::placeholder,
  select {
    color: rgba(255, 255, 255, 0.5);
  }

  select option {
    background-color: #0a1931;
    color: white;
  }

  input:focus,
  textarea:focus,
  select:focus {
    box-shadow: 0 0 0 3px rgba(244, 140, 6, 0.1);
  }
</style>
