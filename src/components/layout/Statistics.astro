---
// Enhanced Stats Section with Vision & Mission
import StatCard from "../ui/StatCard.astro";

const stats = [
  {
    id: "stat-projects",
    title: "Digital Excellence",
    target: 2500,
    suffix: "+",
    description: "Projects Completed",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>',
  },
  {
    id: "stat-experience",
    title: "Industry Expertise",
    target: 8,
    suffix: "+",
    description: "Years Experience",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>',
  },
  {
    id: "stat-clients",
    title: "Client Success",
    target: 450,
    suffix: "+",
    description: "Happy Clients",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1m4 0h1m-6 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>',
  },
  {
    id: "stat-growth",
    title: "Growth Results",
    target: 285,
    suffix: "%",
    description: "Average Growth",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>',
  },
];
---

<section class="bg-parchment py-20 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-8 relative z-10">
    <!-- Section Header -->
    <div class="mb-16">
      <span
        id="who-we-are-tag"
        class="text-sm font-semibold tracking-widest uppercase"
        style="color: var(--helios-orange);"
      >
        WHO WE ARE
      </span>
      <h2
        class="font-bold mb-4 leading-tight mt-4"
        style="font-size: 48px; color: var(--midnight-navy);"
        id="who-we-are-title"
      >
        The Leading Website Design <br />
        Company For <span style="color: var(--helios-orange);">Contractors</span
        >
      </h2>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <!-- Left Side - Image -->
      <div class="space-y-8">
        <!-- Main Image -->
        <div class="relative overflow-hidden">
          <div class="rounded-3xl overflow-hidden shadow-2xl">
            <img
              src="/images/img3.avif"
              alt="Professional construction team working on building project"
              class="w-full h-80 object-cover"
            />
          </div>
          <!-- Swipe reveal overlay -->
          <div
            class="absolute top-0 left-0 w-full h-full bg-[var(--parchment)] z-10 animate-[swipeReveal_1.2s_ease-out_0.3s_forwards]"
          >
          </div>
        </div>
      </div>

      <!-- Right Side - Vision, Mission & Stats -->
      <div class="space-y-12">
        <!-- Vision Section -->
        <div>
          <h3
            class="text-2xl font-bold mb-4"
            style="color: var(--midnight-navy);"
            id="our-vision-title"
          >
            Our Vision
          </h3>
          <p
            class="text-lg leading-relaxed text-[#0A1931]"
            id="our-vision-desc"
          >
            To empower contractors with cutting-edge web solutions that enhance
            their digital presence and drive sustainable business growth in the
            competitive home services market.
          </p>
        </div>

        <!-- Mission Section -->
        <div>
          <h3
            class="text-2xl font-bold mb-4"
            style="color: var(--midnight-navy);"
            id="our-mission-title"
          >
            Our Mission
          </h3>
          <p
            class="text-lg leading-relaxed text-[#0A1931]"
            id="our-mission-desc"
          >
            Our solutions are designed to meet the unique needs of HVAC and
            plumbing contractors, ensuring they thrive in today's competitive
            online landscape through proven digital strategies.
          </p>
        </div>
      </div>
    </div>

    <!-- Stats Cards Row -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-16">
      {
        stats.map((stat) => (
          <StatCard
            id={stat.id}
            title={stat.title}
            target={stat.target}
            suffix={stat.suffix}
            description={stat.description}
            icon={stat.icon}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Swipe reveal animation */
  @keyframes swipeReveal {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(100%);
    }
  }

  /* Scroll animation for moving banner */
  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Scroll animation for moving banner */
  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 1024px) {
    .grid {
      gap: 3rem;
    }
  }

  @media (max-width: 768px) {
    .min-h-\[280px\] {
      min-height: 240px;
    }

    .text-6xl {
      font-size: 3rem;
    }

    .text-5xl {
      font-size: 2.25rem;
    }

    .w-12 {
      width: 2.5rem;
    }

    .h-12 {
      height: 2.5rem;
    }

    .text-xl {
      font-size: 1.125rem;
    }

    .max-w-\[60\%\] {
      max-width: 70%;
    }
  }

  @media (max-width: 640px) {
    .min-h-\[280px\] {
      min-height: 200px;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    // Counter animation function
    function animateCounter(
      element: HTMLElement,
      target: number,
      suffix: string,
      duration: number,
    ) {
      let start = 0;
      const increment = target / (duration / 16);

      function updateCounter() {
        start += increment;
        if (start < target) {
          const currentValue = Math.floor(start).toLocaleString();
          if (suffix.includes("+") || suffix.includes("%")) {
            element.innerHTML =
              currentValue +
              '<span class="text-white text-5xl ml-1 transition-colors duration-400">' +
              suffix +
              "</span>";
          } else {
            element.textContent = currentValue + suffix;
          }
          requestAnimationFrame(updateCounter);
        } else {
          const finalValue = target.toLocaleString();
          if (suffix.includes("+") || suffix.includes("%")) {
            element.innerHTML =
              finalValue +
              '<span class="text-white text-5xl ml-1 transition-colors duration-400">' +
              suffix +
              "</span>";
          } else {
            element.textContent = finalValue + suffix;
          }
        }
      }

      updateCounter();
    }

    // Intersection Observer for counter animation
    const observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            const counters = entry.target.querySelectorAll("[data-target]");

            counters.forEach(function (counter) {
              const targetAttr = counter.getAttribute("data-target");
              const suffixAttr = counter.getAttribute("data-suffix");

              if (targetAttr && !counter.classList.contains("animated")) {
                const target = parseInt(targetAttr, 10);
                const suffix = suffixAttr || "";

                counter.classList.add("animated");
                animateCounter(counter as HTMLElement, target, suffix, 2000);
              }
            });
          }
        });
      },
      {
        threshold: 0.3,
        rootMargin: "0px 0px -50px 0px",
      },
    );

    // Observe the stats section
    const statsSection = document.querySelector(".bg-parchment");
    if (statsSection) {
      observer.observe(statsSection);
    }
  });
</script>

<script src="/src/scripts/scroll-animate.js"></script>
