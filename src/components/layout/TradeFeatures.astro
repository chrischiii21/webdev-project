---
// Trade Features Component - Reusable section for trade-specific features
import Badge from "../ui/Badge.astro";

export interface Props {
    trade: "hvac" | "plumbing";
    backLink?: string;
    title: string;
    subtitle?: string;
    benefits: Array<{
        title: string;
        description: string;
    }>;
    solutionsTitle: string;
    solutions: Array<{
        title: string;
        description: string;
    }>;
}

const {
    trade,
    backLink = "/trades-we-serve",
    title,
    subtitle,
    benefits,
    solutionsTitle,
    solutions,
} = Astro.props;

// Set colors based on trade
const accentColor = trade === "hvac" ? "#0A1931" : "#F48C06";
const badgeText = trade === "hvac" ? "HVAC" : "PLUMBING";
---

<section class="relative pt-20 pb-10 overflow-hidden">
    <!-- Background Elements -->
    <div class="absolute inset-0 bg-gradient-to-br from-[#F5F5F5] via-white to-[#F8FAFC]"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-[#F48C06]/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-[#0A1931]/5 rounded-full blur-3xl"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-8">

        <!-- Section Header -->
        <div class="text-center mb-20">
            <span
                class="text-sm font-semibold tracking-widest uppercase"
                style="color: var(--helios-orange);"
            >
                TRADE SOLUTIONS
            </span>
            <h2 class="text-3xl md:text-3xl lg:text-5xl font-bold text-[#0A1931] mb-8 leading-tight mt-4 max-w-4xl mx-auto">
                {title}
            </h2>
            {
                subtitle && (
            <p class="text-lg text-[#0A1931] max-w-3xl mx-auto leading-relaxed">
                {subtitle} BuildPro.
            </p>
                )
            }
        </div>

        <!-- Benefits Grid -->
        <div class="mb-24">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">
                {
                    benefits.map((benefit, index) => (
                        <div class="group relative">
                            <!-- Main Card -->
                            <div class="relative bg-white rounded-3xl p-8 border border-[#99B0BB]/10 shadow-lg hover:shadow-2xl transition-all duration-500 hover:scale-105 overflow-hidden">
                                <!-- Decorative gradient overlay -->
                                <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-[#F48C06]/10 to-transparent rounded-bl-full"></div>
                                
                                <!-- Icon -->
                                <div class="relative mb-6">
                                    <div
                                        class="w-14 h-14 rounded-2xl flex items-center justify-center shadow-xl transition-all duration-300"
                                        style={`background: linear-gradient(135deg, ${accentColor}, ${accentColor}DD);`}
                                    >
                                        {/* Seasonal Demand Visibility - Calendar/Season icon */}
                                        {benefit.title === "Seasonal Demand Visibility" && (
                                            <svg
                                                class="w-7 h-7 text-white"
                                                fill="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/>
                                            </svg>
                                        )}
                                        
                                        {/* Maintenance Plan Promotions - Tools/Wrench icon */}
                                        {benefit.title === "Maintenance Plan Promotions" && (
                                            <svg
                                                class="w-7 h-7 text-white"
                                                fill="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/>
                                            </svg>
                                        )}
                                        
                                        {/* Emergency Service Availability - Phone/Emergency icon */}
                                        {benefit.title === "Emergency Service Availability" && (
                                            <svg
                                                class="w-7 h-7 text-white"
                                                fill="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56-.35-.12-.74-.03-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/>
                                            </svg>
                                        )}
                                        
                                        {/* Technician Credentials Display - Badge/Certificate icon */}
                                        {benefit.title === "Technician Credentials Display" && (
                                            <svg
                                                class="w-7 h-7 text-white"
                                                fill="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                                                <path d="M12 7c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
                                            </svg>
                                        )}
                                        
                                        {/* Service Area Expansion - Map/Location icon */}
                                        {benefit.title === "Service Area Expansion" && (
                                            <svg
                                                class="w-7 h-7 text-white"
                                                fill="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                                            </svg>
                                        )}
                                        
                                        {/* Energy Efficiency Focus - Leaf/Eco icon */}
                                        {benefit.title === "Energy Efficiency Focus" && (
                                            <svg
                                                class="w-7 h-7 text-white"
                                                fill="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.95-2.3c.48.17.98.3 1.34.3C19 20 22 3 22 3c-1 0-17 2-5 5z"/>
                                                <path d="M3.5 12.5c0 0 2 2 5.5 2s5.5-2 5.5-2-2-2-5.5-2-5.5 2-5.5 2z"/>
                                            </svg>
                                        )}
                                        
                                        {/* Default check icon for any other titles */}
                                        {!["Seasonal Demand Visibility", "Maintenance Plan Promotions", "Emergency Service Availability", "Technician Credentials Display", "Service Area Expansion", "Energy Efficiency Focus", "Emergency Service Visibility", "Online Appointment Booking", "Local SEO & Service Areas", "Customer Reviews Integration", "Mobile-First Design", "Service Portfolio Showcase"].includes(benefit.title) && (
                                            <svg
                                                class="w-7 h-7 text-white"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2.5"
                                                    d="M5 13l4 4L19 7"
                                                />
                                            </svg>
                                        )}

                                        {/* PLUMBING Icons */}
                                        {/* Emergency Service Visibility - Emergency/Alert icon */}
                                        {benefit.title === "Emergency Service Visibility" && (
                                            <svg
                                                class="w-7 h-7 text-white"
                                                fill="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/>
                                            </svg>
                                        )}
                                        
                                        {/* Online Appointment Booking - Calendar/Clock icon */}
                                        {benefit.title === "Online Appointment Booking" && (
                                            <svg
                                                class="w-7 h-7 text-white"
                                                fill="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/>
                                                <path d="M12.5 7H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                                            </svg>
                                        )}
                                        
                                        {/* Local SEO & Service Areas - Map/Location icon */}
                                        {benefit.title === "Local SEO & Service Areas" && (
                                            <svg
                                                class="w-7 h-7 text-white"
                                                fill="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                                            </svg>
                                        )}
                                        
                                        {/* Customer Reviews Integration - Star/Review icon */}
                                        {benefit.title === "Customer Reviews Integration" && (
                                            <svg
                                                class="w-7 h-7 text-white"
                                                fill="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                            </svg>
                                        )}
                                        
                                        {/* Mobile-First Design - Mobile/Phone icon */}
                                        {benefit.title === "Mobile-First Design" && (
                                            <svg
                                                class="w-7 h-7 text-white"
                                                fill="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path d="M17 2H7c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM7 4h10v14H7V4z"/>
                                                <circle cx="12" cy="20" r="1"/>
                                            </svg>
                                        )}
                                        
                                        {/* Service Portfolio Showcase - Gallery/Image icon */}
                                        {benefit.title === "Service Portfolio Showcase" && (
                                            <svg
                                                class="w-7 h-7 text-white"
                                                fill="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                                            </svg>
                                        )}
                                    </div>
                                </div>
                                
                                <!-- Content -->
                                <div class="relative">
                                    <h4 class="text-xl font-bold text-[#0A1931] mb-3 group-hover:text-[#F48C06] transition-colors duration-300">
                                        {benefit.title}
                                    </h4>
                                    <p class="text-base text-[#0A1931] leading-relaxed">
                                        {benefit.description}
                                    </p>
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>

    </div>
</section>