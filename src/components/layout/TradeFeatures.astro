---
// Trade Features Component - Reusable section for trade-specific features
import Badge from "../ui/Badge.astro";
import FeatureCard from "../ui/FeatureCard.astro";

export interface Props {
    trade: "hvac" | "plumbing";
    backLink?: string;
    title: string;
    subtitle?: string;
    benefits: Array<{
        title: string;
        description: string;
    }>;
    solutionsTitle: string;
    solutions: Array<{
        title: string;
        description: string;
    }>;
}

const {
    trade,
    backLink = "/trades-we-serve",
    title,
    subtitle,
    benefits,
    solutionsTitle,
    solutions,
} = Astro.props;

// Set colors based on trade
const accentColor = trade === "hvac" ? "#0A1931" : "#F48C06";
const badgeText = trade === "hvac" ? "HVAC" : "PLUMBING";
---

<section class="relative pt-20 pb-10 overflow-hidden">
    <!-- Background Elements -->
    <div
        class="absolute inset-0 bg-gradient-to-br from-[#F5F5F5] via-white to-[#F8FAFC]"
    >
    </div>
    <div
        class="absolute top-0 right-0 w-96 h-96 bg-[#F48C06]/5 rounded-full blur-3xl"
    >
    </div>
    <div
        class="absolute bottom-0 left-0 w-80 h-80 bg-[#0A1931]/5 rounded-full blur-3xl"
    >
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-8">
        <!-- Section Header -->
        <div class="text-center mb-20">
            <span
                id="trade-features-tag"
                class="text-sm font-semibold tracking-widest uppercase"
                style="color: var(--helios-orange);"
            >
                TRADE SOLUTIONS
            </span>
            <h2
                id="trade-features-title"
                class="text-3xl md:text-3xl lg:text-5xl font-bold text-[#0A1931] mb-8 leading-tight mt-4 max-w-4xl mx-auto"
            >
                {title}
            </h2>
            {
                subtitle && (
                    <p
                        id="trade-features-subtitle"
                        class="text-lg text-[#0A1931] max-w-3xl mx-auto leading-relaxed"
                    >
                        {subtitle} BuildPro.
                    </p>
                )
            }
        </div>

        <!-- Benefits Grid -->
        <div class="mb-24">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">
                {
                    benefits.map((benefit, index) => (
                        <FeatureCard
                            id={`trade-feature-card-${index + 1}`}
                            title={benefit.title}
                            description={benefit.description}
                            accentColor={accentColor}
                        />
                    ))
                }
            </div>
        </div>
    </div>
</section>
