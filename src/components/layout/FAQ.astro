---
// FAQ Component
// Modern accordion UI with left content and right accordion
---

<section
    class="bg-gradient-to-br from-[#0a1931] to-[#1a2a4a] py-20 flex items-center justify-center font-primary"
>
    <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 max-w-7xl w-full items-start px-8"
    >
        <!-- Left Content -->
        <div class="flex flex-col">
            <span
                id="faq-tag"
                class="font-semibold tracking-widest uppercase"
                style="color: var(--helios-orange); font-size: 16px;"
            >
                FAQS          
            </span>
            <h2
                id="faq-title"
                class="text-3xl md:text-5xl font-bold text-white mb-6 leading-tight mt-[16px]"
            >
                Frequently <span class="text-[#F48C06]">Asked </span>Questions
            </h2>
            <p id="faq-desc" class="text-white leading-relaxed max-w-4xl mb-8" style="font-size: 20px;">
                We've compiled a list of answers to address your most pressing
                questions regarding our Services.
            </p>
            
            <!-- Added Visual Elements -->
            <div class="space-y-6">
                <!-- FAQ Image -->
                <div class="relative rounded-2xl overflow-hidden">
                    <img
                        src="/images/img3.avif"
                        alt="Professional contractor consultation"
                        class="w-full h-35 object-cover rounded-2xl"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent rounded-2xl"></div>
                    <div class="absolute bottom-6 left-6 text-white">
                        <div class="text-lg font-semibold mb-1">Expert Consultation</div>
                        <div class="text-white/90 text-sm">Get personalized answers to your questions</div>
                    </div>
                </div>
                
                <!-- Contact CTA -->
                <div class="bg-gradient-to-r from-[#F48C06]/20 to-[#F48C06]/10 backdrop-blur-md rounded-2xl p-6 border border-[#F48C06]/30">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-[#F48C06] rounded-full flex items-center justify-center">
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                            </svg>
                        </div>
                        <div>
                            <div class="text-white font-semibold text-lg">Still have questions?</div>
                            <div class="text-white/80 text-base">Call us at (555) 123-4567</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Accordion -->
        <div id="faq-accordion" class="bg-white/5 rounded-3xl p-6 backdrop-blur-md flex flex-col w-full">
            <div class="flex flex-col flex-1" id="faqAccordion">
                <!-- FAQ Item 1 -->
                <div
                    class="faq-item active border-b border-[#99B0BB]/20 transition-all duration-300"
                >
                    <button
                        class="faq-header w-full flex items-center justify-between py-6 bg-transparent border-none cursor-pointer transition-all duration-300 text-left rounded-lg focus:outline-none"
                        aria-expanded="true"
                        aria-controls="faq-content-1"
                    >
                        <span
                            class="text-lg font-semibold text-white transition-colors duration-300"
                        >
                            How long does a typical project take?
                        </span>
                        <svg
                            class="faq-icon w-6 h-6 text-[#F48C06] shrink-0 transition-transform duration-300"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            aria-hidden="true"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 5v14m7-7H5"></path>
                        </svg>
                    </button>
                    <div
                        class="faq-content overflow-hidden transition-all duration-300"
                        id="faq-content-1"
                    >
                        <p
                            class="text-white leading-relaxed px-2 pt-4 pb-6 animate-slideDown"
                            style="font-size: 16px;"
                        >
                            Project timelines vary depending on scope and
                            complexity. Most residential projects take between
                            1-4 weeks. We'll provide a timeline during
                            initial consultation.
                        </p>
                    </div>
                </div>

                <!-- FAQ Item 2 -->
                <div
                    class="faq-item border-b border-[#99B0BB]/20 transition-all duration-300"
                >
                    <button
                        class="faq-header w-full flex items-center justify-between py-6 bg-transparent border-none cursor-pointer transition-all duration-300 text-left rounded-lg focus:outline-none"
                        aria-expanded="false"
                        aria-controls="faq-content-2"
                    >
                        <span
                            class="text-lg font-semibold text-white transition-colors duration-300"
                        >
                            Do you offer warranties on your work?
                        </span>
                        <svg
                            class="faq-icon w-6 h-6 text-[#F48C06] shrink-0 transition-transform duration-300"
                            aria-hidden="true"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 5v14m7-7H5"></path>
                        </svg>
                    </button>
                    <div
                        class="faq-content hidden overflow-hidden transition-all duration-300"
                        id="faq-content-2"
                    >
                        <p
                            class="text-white leading-relaxed px-2 pt-4 pb-6 animate-slideDown"
                            style="font-size: 16px;"
                        >
                            Yes, we stand behind our work. All projects come
                            with a 1-year warranty on labor and materials.
                            Extended warranties are available for additional
                            peace of mind.
                        </p>
                    </div>
                </div>

                <!-- FAQ Item 3 -->
                <div
                    class="faq-item border-b border-[#99B0BB]/20 transition-all duration-300"
                >
                    <button
                        class="faq-header w-full flex items-center justify-between py-6 bg-transparent border-none cursor-pointer transition-all duration-300 text-left rounded-lg focus:outline-none"
                        aria-expanded="false"
                        aria-controls="faq-content-3"
                    >
                        <span
                            class="text-lg font-semibold text-white transition-colors duration-300"
                        >
                            What payment methods do you accept?
                        </span>
                        <svg
                            class="faq-icon w-6 h-6 text-[#F48C06] shrink-0 transition-transform duration-300"
                            aria-hidden="true"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 5v14m7-7H5"></path>
                        </svg>
                    </button>
                    <div
                        class="faq-content hidden overflow-hidden transition-all duration-300"
                        id="faq-content-3"
                    >
                        <p
                            class="text-white leading-relaxed px-2 pt-4 pb-6 animate-slideDown"
                            style="font-size: 16px;"
                        >
                            We accept major credit cards, checks, bank
                            transfers, and financing options. A 50% deposit is
                            required to schedule your project, with the balance
                            due upon completion.
                        </p>
                    </div>
                </div>

                <!-- FAQ Item 4 -->
                <div
                    class="faq-item border-b border-[#99B0BB]/20 transition-all duration-300"
                >
                    <button
                        class="faq-header w-full flex items-center justify-between py-6 bg-transparent border-none cursor-pointer transition-all duration-300 text-left rounded-lg focus:outline-none"
                        aria-expanded="false"
                        aria-controls="faq-content-4"
                    >
                        <span
                            class="text-lg font-semibold text-white transition-colors duration-300"
                        >
                            Are your contractors licensed and insured?
                        </span>
                        <svg
                            class="faq-icon w-6 h-6 text-[#F48C06] shrink-0 transition-transform duration-300"
                            aria-hidden="true"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 5v14m7-7H5"></path>
                        </svg>
                    </button>
                    <div
                        class="faq-content hidden overflow-hidden transition-all duration-300"
                        id="faq-content-4"
                    >
                        <p
                            class="text-white leading-relaxed px-2 pt-4 pb-6 animate-slideDown"
                            style="font-size: 16px;"
                        >
                            Absolutely. All our contractors are fully licensed,
                            insured, and bonded. We verify credentials for every
                            team member and maintain comprehensive liability
                            coverage.
                        </p>
                    </div>
                </div>

                <!-- FAQ Item 5 -->
                <div class="faq-item transition-all duration-300">
                    <button
                        class="faq-header w-full flex items-center justify-between py-6 bg-transparent border-none cursor-pointer transition-all duration-300 text-left rounded-lg focus:outline-none"
                        aria-expanded="false"
                        aria-controls="faq-content-5"
                    >
                        <span
                            class="text-lg font-semibold text-white transition-colors duration-300"
                        >
                            How do I get a free estimate?
                        </span>
                        <svg
                            class="faq-icon w-6 h-6 text-[#F48C06] shrink-0 transition-transform duration-300"
                            aria-hidden="true"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 5v14m7-7H5"></path>
                        </svg>
                    </button>
                    <div
                        class="faq-content hidden overflow-hidden transition-all duration-300"
                        id="faq-content-5"
                    >
                        <p
                            class="text-white leading-relaxed px-2 pt-4 pb-6 animate-slideDown"
                            style="font-size: 16px;"
                        >
                            Simply fill out our contact form or call us
                            directly. We'll schedule a convenient time to visit
                            your property, assess the work, and provide a
                            detailed, no-obligation estimate.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* Active state styles */
    .faq-item.active .faq-icon {
        transform: rotate(45deg);
    }

    .faq-item.active .faq-header span {
        color: #f48c06;
    }

    .faq-header:hover span {
        color: #f48c06;
    }

    @keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-slideDown {
        animation: slideDown 0.3s ease-out;
    }
</style>

<script src="/src/scripts/faq.js"></script>
