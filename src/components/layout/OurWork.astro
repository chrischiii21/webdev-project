---
// Our Work Section - Combined HVAC & Plumbing Templates
import { getCollection } from "astro:content";
import Button from "../ui/Button.astro";
import TemplateCard from "../ui/TemplateCard.astro";

// Get all templates and filter by trade
const allTemplates = await getCollection("templates");

// Group templates by trade and get the first one from each
const templatesByTrade = allTemplates.reduce(
    (acc, template) => {
        const trade = template.data.trade.toLowerCase();
        if (!acc[trade]) {
            acc[trade] = template;
        }
        return acc;
    },
    {} as Record<string, (typeof allTemplates)[0]>,
);

const tradeTemplates = Object.values(templatesByTrade);
---

<section class="py-20 bg-parchment">
    <div class="max-w-7xl mx-auto px-8">
        <!-- Section Header -->
        <div class="text-center mb-16">
            <span
                id="our-work-tag"
                class="font-semibold tracking-widest uppercase"
                style="color: var(--helios-orange); font-size: 16px;"
            >
                FEATURED WORK
            </span>
            <h2
                id="our-work-title"
                class="text-4xl md:text-5xl font-bold text-[#0A1931] mb-6 mt-4"
            >
                Our <span style="color: var(--helios-orange);">Works</span>
            </h2>
            <p
                id="our-work-desc"
                class="text-[#0A1931] max-w-5xl mx-auto"
                style="font-size: 22px;"
            >
                Explore our portfolio of professional websites designed for HVAC
                and plumbing contractors.
            </p>
        </div>

        <!-- Templates Grid - One per Trade -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {
                tradeTemplates.map((template) => {
                    const tradeLower = template.data.trade.toLowerCase() as
                        | "hvac"
                        | "plumbing";
                    return (
                        <TemplateCard
                            href={`/trades-we-serve/${tradeLower}`}
                            imageSrc={
                                template.data.thumbnail || "/images/web1.png"
                            }
                            imageAlt={template.data.title}
                            title={`View ${template.data.trade} Templates`}
                            description={`Explore all ${tradeLower} designs →`}
                            trade={tradeLower}
                        />
                    );
                })
            }
        </div>

        <!-- View All Button -->
        <div id="our-work-cta" class="text-center mt-16">
            <Button
                href="/our-work"
                variant="primary"
                size="lg"
                ariaLabel="View all completed projects"
            >
                View All Projects
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </Button>
        </div>
    </div>
</section>
