---
// ServicePillars Component - Core service offerings for marketing agency
// Displays three key pillars: Template Architecture, Conversion Optimization, Local SEO Integration
import Card from "../ui/Card.astro";

export interface Props {
    eyebrow?: string;
    heading?: string;
    subheading?: string;
}

const {
    eyebrow = "OUR CORE OFFERING",
    heading = "Digital blueprints built for business growth",
    subheading = "Specialized website templates for Plumbing and HVAC companies",
} = Astro.props;

const pillars = [
    {
        id: "architecture",
        icon: "cpu",
        title: "Template Architecture",
        description:
            "Built with Astro and Tailwind CSS, our templates are lightning-fast and responsive, ensuring your customers find you before they find competition.",
    },
    {
        id: "conversion",
        icon: "phone",
        title: "Conversion Optimization",
        description:
            "Every button and form is strategically placed with one goal in mind: getting the phone to ring. We specialize in 'Emergency Call' patterns.",
    },
    {
        id: "seo",
        icon: "map",
        title: "Local SEO Integration",
        description:
            "Our code includes pre-configured Schema markup, helping Google understand exactly which specific zip codes and areas you serve.",
    },
];
---

<section class="py-20 bg-parchment">
    <div class="container-custom">
        <!-- Section Header -->
        <div class="text-center mb-16">
            <span
                class="text-sm font-semibold tracking-widest uppercase"
                style="color: var(--helios-orange);"
            >
                {eyebrow}
            </span>
            <h2 class="heading-primary mt-4 mb-4">{heading}</h2>
            <p class="text-lg text-[#0A1931] max-w-2xl mx-auto leading-relaxed">
                {subheading}
            </p>
        </div>

        <!-- Pillars Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10">
            {
                pillars.map((pillar) => (
                    <Card title={pillar.title} description={pillar.description}>
                        <div class="flex flex-col items-start mb-6">
                            <div
                                class="w-16 h-16 rounded-lg flex items-center justify-center transition-all duration-300 group-hover:scale-110 mb-4"
                                style="background-color: rgba(244, 140, 6, 0.1);"
                            >
                                {pillar.icon === "cpu" && (
                                    <svg
                                        class="w-8 h-8"
                                        style="color: var(--helios-orange);"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        aria-hidden="true"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 3v2m6-2v2m6-2v2M9 3H7a2 2 0 00-2 2v2m16-4v2m0 6H3m0 6h18v2a2 2 0 01-2 2H5a2 2 0 01-2-2v-2zm0-6V9a2 2 0 012-2h14a2 2 0 012 2v6M9 19v2m6-2v2"
                                        />
                                    </svg>
                                )}
                                {pillar.icon === "phone" && (
                                    <svg
                                        class="w-8 h-8"
                                        style="color: var(--helios-orange);"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        aria-hidden="true"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                        />
                                    </svg>
                                )}
                                {pillar.icon === "map" && (
                                    <svg
                                        class="w-8 h-8"
                                        style="color: var(--helios-orange);"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        aria-hidden="true"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                        />
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                        />
                                    </svg>
                                )}
                            </div>
                        </div>
                    </Card>
                ))
            }
        </div>
    </div>
</section>
