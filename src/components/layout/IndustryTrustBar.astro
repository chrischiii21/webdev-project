---
// Industry Trust Bar - Compact banner style certification showcase

const certifications = [
    {
        id: "nate",
        name: "NATE",
        icon: "nate",
        stat: "25K+",
        label: "Certified",
    },
    { id: "phcc", name: "PHCC", icon: "phcc", stat: "4.5K+", label: "Members" },
    {
        id: "google",
        name: "Google",
        icon: "google",
        stat: "4.9★",
        label: "Rated",
    },
    { id: "yelp", name: "Yelp", icon: "yelp", stat: "98%", label: "Positive" },
];

const getIcon = (type: string) => {
    // Return actual brand logo SVG markup
    const logos: Record<string, string> = {
        nate: `<svg viewBox="0 0 100 100" fill="none"><rect width="100" height="100" rx="10" fill="#003366"/><text x="50" y="60" font-family="Arial, sans-serif" font-size="32" font-weight="bold" fill="white" text-anchor="middle">NATE</text></svg>`,
        phcc: `<svg viewBox="0 0 100 100" fill="none"><rect width="100" height="100" rx="10" fill="#C41E3A"/><text x="50" y="60" font-family="Arial, sans-serif" font-size="28" font-weight="bold" fill="white" text-anchor="middle">PHCC</text></svg>`,
        google: `<svg viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/><path fill="none" d="M0 0h48v48H0z"/></svg>`,
        yelp: `<svg viewBox="0 0 48 48"><path fill="#D32323" d="M24.75 14.17l-3.11 9.5c-.11.34.05.71.37.87l8.94 4.45c.49.24 1.07-.13 1.07-.68v-.77c0-.58-.34-1.11-.87-1.34l-7.75-3.36c-.53-.23-1.14.03-1.32.56l-.33.77zm-3.47-11.67c-.56 0-1.06.39-1.18.94l-5.42 24.17c-.12.56.25 1.11.81 1.22l1.1.22c.57.11 1.1-.25 1.22-.81l5.42-24.17c.12-.56-.25-1.11-.81-1.22l-1.1-.22c-.04-.01-.08-.01-.12-.01zm14.31 19.89l-8.2-5.3c-.44-.28-1.02-.16-1.31.27l-.41.63c-.28.44-.16 1.02.27 1.31l8.2 5.3c.44.28 1.02.16 1.31-.27l.41-.63c.28-.44.16-1.02-.27-1.31zm-25.68 4.28l8.2 5.3c.44.28 1.02.16 1.31-.27l.41-.63c.28-.44.16-1.02-.27-1.31l-8.2-5.3c-.44-.28-1.02-.16-1.31.27l-.41.63c-.28.44-.16 1.02.27 1.31z"/></svg>`,
    };
    return logos[type] || logos.nate;
};
---

<section class="py-16 md:py-20 bg-white relative overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute inset-0 opacity-5">
        <div class="absolute top-0 left-0 w-96 h-96 bg-[var(--helios-orange)] rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-[var(--midnight-navy)] rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 md:px-8 relative z-10">
        <!-- Header -->
        <div id="trust-header" class="text-center mb-12">
            <div class="inline-flex items-center gap-2 mb-4">
                <span class="text-[var(--helios-orange)] font-semibold text-sm uppercase tracking-wider">Industry Recognition</span>
            </div>
            <h2 class="font-bold text-[var(--midnight-navy)] mb-3" style="font-size: 48px;">
                Trusted by <span class="text-[var(--helios-orange)]">10,000+</span> Contractors
            </h2>
            <p class="text-[#0a1931] text-lg max-w-2xl mx-auto">
                Partnering with industry leaders to deliver excellence
            </p>
        </div>

        <!-- Certification Cards Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {
                certifications.map((cert, index) => (
                    <div 
                        id={`cert-${cert.id}`}
                        class="group relative bg-white border-2 border-[var(--steel-pewter)]/30 rounded-2xl p-6 hover:border-[var(--helios-orange)] transition-all duration-300 hover:shadow-[0_8px_30px_rgba(244,140,6,0.15)] hover:-translate-y-1"
                    >
                        <!-- Icon -->
                        <div class="mb-4">
                            <div class="w-14 h-14 rounded-xl bg-white border-2 border-[var(--steel-pewter)]/20 flex items-center justify-center group-hover:scale-110 transition-transform duration-300 shadow-sm group-hover:border-[var(--helios-orange)]/30">
                                <div class="w-8 h-8" set:html={getIcon(cert.icon)} />
                            </div>
                        </div>

                        <!-- Content -->
                        <div>
                            <h3 class="text-xl font-bold text-[var(--midnight-navy)] mb-2">
                                {cert.name}
                            </h3>
                            <div class="flex items-baseline gap-2">
                                <span class="text-2xl font-extrabold text-[var(--helios-orange)]">
                                    {cert.stat}
                                </span>
                                <span class="text-sm text-[#0a1931]">
                                    {cert.label}
                                </span>
                            </div>
                        </div>

                        <!-- Decorative corner accent -->
                        <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-br from-[var(--helios-orange)]/10 to-transparent rounded-bl-full opacity-100 group-hover:opacity-0 transition-opacity duration-300"></div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
<script src="/src/scripts/scroll-animate.js"></script> 