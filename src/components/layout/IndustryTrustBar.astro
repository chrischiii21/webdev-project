---
// Industry Trust Bar - Compact banner style certification showcase

const certifications = [
    {
        id: "nate",
        name: "NATE",
        icon: "nate",
        stat: "25K+",
        label: "Certified",
    },
    { id: "phcc", name: "PHCC", icon: "phcc", stat: "4.5K+", label: "Members" },
    {
        id: "google",
        name: "Google",
        icon: "google",
        stat: "4.9★",
        label: "Rated",
    },
    { id: "yelp", name: "Yelp", icon: "yelp", stat: "98%", label: "Positive" },
];

const getIcon = (type: string) => {
    const icons: Record<string, string> = {
        nate: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
        phcc: "M13 10V3L4 14h7v7l9-11h-7z",
        google: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z",
        yelp: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z",
    };
    return icons[type] || icons.nate;
};
---

<section class="py-16 md:py-20 bg-white relative overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute inset-0 opacity-5">
        <div class="absolute top-0 left-0 w-96 h-96 bg-[var(--helios-orange)] rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-[var(--midnight-navy)] rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 md:px-8 relative z-10">
        <!-- Header -->
        <div id="trust-header" class="text-center mb-12">
            <div class="inline-flex items-center gap-2 mb-4">
                <svg class="w-6 h-6 text-[var(--helios-orange)]" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-[var(--helios-orange)] font-semibold text-sm uppercase tracking-wider">Industry Recognition</span>
            </div>
            <h2 class="text-3xl md:text-4xl font-bold text-[var(--midnight-navy)] mb-3">
                Trusted by <span class="text-[var(--helios-orange)]">10,000+</span> Contractors
            </h2>
            <p class="text-[var(--machinist)] text-lg max-w-2xl mx-auto">
                Partnering with industry leaders to deliver excellence
            </p>
        </div>

            <!-- Right: Certification Badges -->
            <div class="flex gap-3 md:gap-4 flex-nowrap">
                {
                    certifications.map((cert) => (
                        <div class="group bg-white border border-[#99B0BB] rounded-xl overflow-hidden hover:shadow-xl hover:-translate-y-2 transition-all duration-300 hover:border-[#F48C06] px-5 md:px-6 py-4 flex items-center gap-3 min-h-[80px]">
                            <div class="w-10 h-10 md:w-11 md:h-11 rounded-full flex items-center justify-center shrink-0 bg-gradient-to-br from-[var(--helios-orange)] to-[#ff6b35] transition-all duration-300 group-hover:scale-110">
                                <svg
                                    class="w-5 h-5 md:w-6 md:h-6 text-white"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d={getIcon(cert.icon)}
                                    />
                                </svg>
                            </div>
                            <div class="flex flex-col gap-1 flex-1">
                                <span class="text-sm md:text-base font-bold text-[#0A1931] leading-none transition-colors duration-300 group-hover:text-[#F48C06]">
                                    {cert.name}
                                </span>
                                <span class="text-xs md:text-sm text-[#0A1931] leading-none transition-colors duration-300 group-hover:text-[#F48C06]">
                                    {cert.stat} {cert.label}
                                </span>
                            </div>
                        </div>

                        <!-- Decorative corner accent -->
                        <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-br from-[var(--helios-orange)]/10 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
<script src="/src/scripts/scroll-animate.js"></script>