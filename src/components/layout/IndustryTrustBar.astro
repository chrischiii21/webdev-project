---
// Industry Trust Bar - Compact banner style certification showcase

const certifications = [
    {
        id: "nate",
        name: "NATE",
        icon: "nate",
        stat: "25K+",
        label: "Certified",
    },
    { id: "phcc", name: "PHCC", icon: "phcc", stat: "4.5K+", label: "Members" },
    {
        id: "google",
        name: "Google",
        icon: "google",
        stat: "4.9★",
        label: "Rated",
    },
    { id: "yelp", name: "Yelp", icon: "yelp", stat: "98%", label: "Positive" },
];

const getIcon = (type: string) => {
    const icons: Record<string, string> = {
        nate: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
        phcc: "M13 10V3L4 14h7v7l9-11h-7z",
        google: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z",
        yelp: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z",
    };
    return icons[type] || icons.nate;
};
---

<section
    class="py-12 md:py-14 bg-parchment border-y border-[#E5E7EB] relative overflow-hidden"
>
    <div
        class="absolute inset-0 bg-linear-to-r from-[#F48C06]/5 via-transparent to-[#1B4D7E]/5 -z-10"
    >
    </div>

    <div class="container-custom">
        <div
            class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 md:gap-8"
        >
            <!-- Left: Trust Statement -->
            <div class="flex items-center gap-3 shrink-0">
                <div class="flex gap-1">
                    <svg
                        class="w-7 h-7 text-[#F48C06]"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                        aria-hidden="true"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                            clip-rule="evenodd"></path>
                    </svg>
                    <svg
                        class="w-7 h-7 text-[#F48C06]"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                        aria-hidden="true"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                            clip-rule="evenodd"></path>
                    </svg>
                    <svg
                        class="w-7 h-7 text-[#F48C06]"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                        aria-hidden="true"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                            clip-rule="evenodd"></path>
                    </svg>
                </div>
                <span
                    class="text-lg md:text-[18px] font-semibold text-[#0A1931]"
                    >Trusted by <span style="color: var(--helios-orange);"
                        >10,000+</span
                    > contractors</span
                >
            </div>
            <h2 class="text-3xl md:text-4xl font-bold text-[var(--midnight-navy)] mb-3">
                Trusted by <span class="text-[var(--helios-orange)]">10,000+</span> Contractors
            </h2>
            <p class="text-[var(--machinist)] text-lg max-w-2xl mx-auto">
                Partnering with industry leaders to deliver excellence
            </p>
        </div>

            <!-- Right: Certification Badges -->
            <div class="flex gap-3 md:gap-4 flex-nowrap">
                {
                    certifications.map((cert) => (
                        <div class="group bg-[var(--midnight-navy)] hover:bg-[var(--helios-orange)] px-5 md:px-6 py-4 rounded-2xl transition-all duration-400 border border-white/10 hover:shadow-[0_10px_25px_rgba(244,140,6,0.3)] flex items-center gap-3 min-h-[80px]">
                            <div
                                class="w-10 h-10 md:w-11 md:h-11 rounded-full flex items-center justify-center shrink-0 bg-white/10 transition-all duration-400 group-hover:bg-white/20 group-hover:scale-105"
                            >
                                <svg
                                    class="w-7 h-7 text-white"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d={getIcon(cert.icon)}
                                    />
                                </svg>
                            </div>
                        </div>

                        <!-- Content -->
                        <div>
                            <h3 class="text-xl font-bold text-[var(--midnight-navy)] mb-2 group-hover:text-[var(--helios-orange)] transition-colors duration-300">
                                {cert.name}
                            </h3>
                            <div class="flex items-baseline gap-2">
                                <span class="text-2xl font-extrabold text-[var(--helios-orange)]">
                                    {cert.stat}
                                </span>
                                <span class="text-sm text-[var(--machinist)] group-hover:text-[var(--midnight-navy)] transition-colors duration-300">
                                    {cert.label}
                                </span>
                            </div>
                        </div>

                        <!-- Decorative corner accent -->
                        <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-br from-[var(--helios-orange)]/10 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
<script src="/src/scripts/scroll-animate.js"></script>