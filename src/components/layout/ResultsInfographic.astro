---
// Results Infographic - Compact metrics summary
// Displays key performance indicators in a minimal, non-redundant format
import StatCard from "../ui/StatCard.astro";

const metrics = [
  {
    id: "results-card-1",
    title: "Websites Built",
    target: 2500,
    suffix: "+",
    description: "Websites Built",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20H7m6-4h.01M9 20h6"></path>',
  },
  {
    id: "results-card-2",
    title: "Lead Increase",
    target: 150,
    suffix: "%",
    description: "Lead Increase",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8L5.586 19.414M7 13v8m0 0H3m4 0v-4"></path>',
  },
  {
    id: "results-card-3",
    title: "Client Rating",
    target: 4.9,
    suffix: "/5",
    description: "Client Rating",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>',
  },
];
---

<section
  class="py-12 md:py-16 px-6 bg-parchment border-y border-[#E5E7EB] relative overflow-hidden results-infographic"
>
  <div
    class="absolute inset-0 bg-linear-to-r from-[#F48C06]/5 via-transparent to-[#1B4D7E]/5 -z-10"
  >
  </div>

  <div class="container-custom">
    <!-- Header -->
    <div class="text-center mb-10 md:mb-12">
      <span
        id="results-tag"
        class="text-sm font-semibold tracking-widest uppercase"
        style="color: var(--helios-orange);">PROVEN RESULTS</span
      >
      <h2 id="results-title" class="heading-primary mt-3 mb-2">
        Real Impact, Real Numbers
      </h2>
      <p
        id="results-desc"
        class="text-lg text-[#0A1931] max-w-3xl mx-auto mt-4"
      >
        Join thousands of contractors transforming their digital presence with
        BuildPro.
      </p>
    </div>

    <!-- Metrics Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        metrics.map((metric) => (
          <StatCard
            id={metric.id}
            title={metric.title}
            target={metric.target}
            suffix={metric.suffix}
            description={metric.description}
            icon={metric.icon}
          />
        ))
      }
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    // Counter animation function
    function animateCounter(
      element: HTMLElement,
      target: number,
      suffix: string,
      duration: number,
    ) {
      let start = 0;
      const increment = target / (duration / 16);

      function updateCounter() {
        start += increment;
        if (start < target) {
          const currentValue =
            target % 1 !== 0
              ? start.toFixed(1)
              : Math.floor(start).toLocaleString();
          element.innerHTML =
            currentValue +
            '<span class="text-white text-5xl ml-1 transition-colors duration-400">' +
            suffix +
            "</span>";
          requestAnimationFrame(updateCounter);
        } else {
          const finalValue =
            target % 1 !== 0 ? target.toFixed(1) : target.toLocaleString();
          element.innerHTML =
            finalValue +
            '<span class="text-white text-5xl ml-1 transition-colors duration-400">' +
            suffix +
            "</span>";
        }
      }

      updateCounter();
    }

    // Intersection Observer for counter animation
    const observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            const counters = entry.target.querySelectorAll("[data-target]");

            counters.forEach(function (counter) {
              const targetAttr = counter.getAttribute("data-target");
              const suffixAttr = counter.getAttribute("data-suffix");

              if (targetAttr && !counter.classList.contains("animated")) {
                const target = parseFloat(targetAttr);
                const suffix = suffixAttr || "";

                counter.classList.add("animated");
                animateCounter(counter as HTMLElement, target, suffix, 2000);
              }
            });
          }
        });
      },
      {
        threshold: 0.3,
        rootMargin: "0px 0px -50px 0px",
      },
    );

    // Observe the results section specifically
    const resultsSection = document.querySelector(".results-infographic");
    if (resultsSection) {
      observer.observe(resultsSection);
    }
  });
</script>
