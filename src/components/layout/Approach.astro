---
// Approach Component - Showcases the company's methodology and process
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";

export interface Props {
    title?: string;
    highlightWord?: string;
    description?: string;
}

const {
    title = "Our Approach",
    highlightWord = "Approach",
    description = "We combine industry expertise with cutting-edge technology to deliver solutions that transform your business.",
} = Astro.props;

const titleParts = title.split(highlightWord);
---

<section class="relative py-20 overflow-hidden">
    <!-- Dynamic Background with Geometric Patterns -->
    <div
        class="absolute inset-0 bg-gradient-to-br from-[#0A1931] via-[#0F1E3A] to-[#1A2B4D]"
    >
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-8">
        <!-- Header Section -->
        <div class="text-center mb-16 approach-header">
            <span
                class="text-sm font-semibold tracking-widest uppercase mb-4 inline-block"
                style="color: var(--helios-orange);"
            >
                HOW WE WORK
            </span>
            <h2
                class="text-4xl md:text-5xl font-bold text-white mb-8 leading-tight"
            >
                {titleParts[0]}
                <span
                    class="text-[#F48C06] relative inline-block highlight-word"
                >
                    {highlightWord}
                </span>
                {titleParts[1]}
            </h2>
            <p class="text-lg text-white max-w-1xl mx-auto leading-relaxed">
                {description}
            </p>
        </div>

        <!-- Main Content Grid -->
        <div class="grid grid-cols-1 xl:grid-cols-3 gap-8 lg:gap-12">
            <!-- Process Steps - Takes 2 columns -->
            <div class="xl:col-span-2 space-y-6 approach-steps">
                <!-- Step 1 -->
                <div class="approach-step group relative">
                    <div
                        class="flex items-start gap-6 p-8 rounded-3xl bg-gradient-to-r from-white/5 to-white/2 backdrop-blur-sm border border-white/10 hover:border-[#F48C06]/30 transition-all duration-500 hover:shadow-2xl hover:shadow-[#F48C06]/10"
                    >
                        <!-- Step Number -->
                        <div class="flex-shrink-0 relative">
                            <div
                                class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#F48C06] to-[#E67E22] flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                            >
                                <span class="text-2xl font-bold text-white"
                                    >01</span
                                >
                            </div>
                            <!-- Connecting Line -->
                            <div
                                class="absolute top-20 left-1/2 w-0.5 h-12 bg-gradient-to-b from-[#F48C06]/50 to-transparent transform -translate-x-1/2"
                            >
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="flex-1 pt-2">
                            <h3
                                class="text-xl font-bold text-white mb-4 group-hover:text-[#F48C06] transition-colors duration-300"
                            >
                                Deep Industry Understanding
                            </h3>
                            <p class="text-white text-base leading-relaxed">
                                We specialize exclusively in contractor and
                                trades businesses, understanding your unique
                                challenges and opportunities better than anyone
                                else.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Step 2 -->
                <div class="approach-step group relative">
                    <div
                        class="flex items-start gap-6 p-8 rounded-3xl bg-gradient-to-r from-white/5 to-white/2 backdrop-blur-sm border border-white/10 hover:border-[#F48C06]/30 transition-all duration-500 hover:shadow-2xl hover:shadow-[#F48C06]/10"
                    >
                        <!-- Step Number -->
                        <div class="flex-shrink-0 relative">
                            <div
                                class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#F48C06] to-[#E67E22] flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                            >
                                <span class="text-2xl font-bold text-white"
                                    >02</span
                                >
                            </div>
                            <!-- Connecting Line -->
                            <div
                                class="absolute top-20 left-1/2 w-0.5 h-12 bg-gradient-to-b from-[#F48C06]/50 to-transparent transform -translate-x-1/2"
                            >
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="flex-1 pt-2">
                            <h3
                                class="text-xl font-bold text-white mb-4 group-hover:text-[#F48C06] transition-colors duration-300"
                            >
                                Data-Driven Strategy
                            </h3>
                            <p class="text-white text-base leading-relaxed">
                                Every decision is backed by analytics and market
                                research, ensuring your investment delivers
                                measurable ROI and sustainable growth.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Step 3 -->
                <div class="approach-step group relative">
                    <div
                        class="flex items-start gap-6 p-8 rounded-3xl bg-gradient-to-r from-white/5 to-white/2 backdrop-blur-sm border border-white/10 hover:border-[#F48C06]/30 transition-all duration-500 hover:shadow-2xl hover:shadow-[#F48C06]/10"
                    >
                        <!-- Step Number -->
                        <div class="flex-shrink-0 relative">
                            <div
                                class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#F48C06] to-[#E67E22] flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                            >
                                <span class="text-2xl font-bold text-white"
                                    >03</span
                                >
                            </div>
                            <!-- Connecting Line -->
                            <div
                                class="absolute top-20 left-1/2 w-0.5 h-12 bg-gradient-to-b from-[#F48C06]/50 to-transparent transform -translate-x-1/2"
                            >
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="flex-1 pt-2">
                            <h3
                                class="text-xl font-bold text-white mb-4 group-hover:text-[#F48C06] transition-colors duration-300"
                            >
                                Continuous Optimization
                            </h3>
                            <p class="text-white text-base leading-relaxed">
                                We don't just launch and leave. Our team
                                continuously monitors, tests, and optimizes your
                                digital presence for peak performance.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Step 4 -->
                <div class="approach-step group relative">
                    <div
                        class="flex items-start gap-6 p-8 rounded-3xl bg-gradient-to-r from-white/5 to-white/2 backdrop-blur-sm border border-white/10 hover:border-[#F48C06]/30 transition-all duration-500 hover:shadow-2xl hover:shadow-[#F48C06]/10"
                    >
                        <!-- Step Number -->
                        <div class="flex-shrink-0">
                            <div
                                class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#F48C06] to-[#E67E22] flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                            >
                                <span class="text-2xl font-bold text-white"
                                    >04</span
                                >
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="flex-1 pt-2">
                            <h3
                                class="text-xl font-bold text-white mb-4 group-hover:text-[#F48C06] transition-colors duration-300"
                            >
                                Partnership Mindset
                            </h3>
                            <p class="text-white text-base leading-relaxed">
                                Your success is our success. We build long-term
                                relationships based on trust, transparency, and
                                shared goals for growth.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar Content -->
            <div class="xl:col-span-1 space-y-8 approach-sidebar">
                <!-- Visual Element -->
                <div class="relative approach-visual">
                    <div
                        class="relative rounded-3xl overflow-hidden shadow-2xl group"
                    >
                        <img
                            src="https://images.unsplash.com/photo-1552664730-d307ca884978?q=80&w=2070&auto=format&fit=crop"
                            alt="Team collaboration"
                            class="w-full h-80 object-cover transition-transform duration-700 group-hover:scale-105"
                        />
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-[#0A1931]/90 via-[#0A1931]/20 to-transparent"
                        >
                        </div>
                    </div>
                </div>

                <!-- Enhanced 50+ Expert Team Card -->
                <div class="approach-stats">
                    <div
                        class="group bg-gradient-to-br from-white/20 to-white/10 backdrop-blur-md rounded-3xl p-8 border border-white/30 hover:border-[#F48C06]/60 transition-all duration-500 hover:bg-gradient-to-br hover:from-white/25 hover:to-white/15 hover:-translate-y-2 hover:shadow-2xl hover:shadow-[#F48C06]/20"
                    >
                        <div class="flex items-center gap-6">
                            <div
                                class="relative w-16 h-16 rounded-2xl bg-gradient-to-br from-[#F48C06] to-[#E67E22] flex items-center justify-center shadow-xl group-hover:scale-110 transition-transform duration-300"
                            >
                                <svg
                                    class="w-8 h-8 text-white"
                                    fill="currentColor"
                                    viewBox="0 0 20 20"
                                >
                                    <path
                                        d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"
                                    ></path>
                                </svg>
                                <!-- Glow effect -->
                                <div class="absolute inset-0 rounded-2xl bg-[#F48C06]/30 blur-lg group-hover:blur-xl transition-all duration-300"></div>
                            </div>
                            <div class="flex-1">
                                <div
                                    class="text-3xl font-bold text-white mb-1 group-hover:text-[#F48C06] transition-colors duration-300"
                                >
                                    50+
                                </div>
                                <div class="text-base text-white/90 font-semibold mb-1">
                                    Expert Team Members
                                </div>
                                <div class="text-sm text-white/70">
                                    Dedicated to your success
                                </div>
                                
                                <!-- Progress bar -->
                                <div class="mt-3 w-full bg-white/20 rounded-full h-1.5 overflow-hidden">
                                    <div class="h-full bg-gradient-to-r from-[#F48C06] to-[#E67E22] rounded-full w-4/5 group-hover:w-full transition-all duration-1000"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Enhanced CTA Section -->
                <div class="approach-cta relative">
                    <!-- Background decoration -->
                    <div class="absolute inset-0 bg-gradient-to-r from-[#F48C06]/10 to-[#E67E22]/10 rounded-3xl blur-xl"></div>
                    
                    <div class="relative">
                        <Button href="/contact" variant="primary" size="lg" fullWidth>
                            <span class="flex items-center justify-center gap-3">
                                Start Your Journey
                                <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                                </svg>
                            </span>
                        </Button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    // Enhanced Intersection Observer for staggered fade-in animations
    const observerOptions = {
        threshold: 0.15,
        rootMargin: "0px 0px -80px 0px",
    };

    /**
     * Letter-by-Letter Fade-In Animation Script
     * This script creates a staggered fade-in effect where each letter
     * of the title appears one by one with a smooth opacity transition.
     */
    function animateTitle(
        selector = "#approach-title",
        delayPerLetter = 80,
        duration = 600,
    ): void {
        const titleElement = document.querySelector(selector) as HTMLElement;
        if (!titleElement) {
            console.warn(`Element with selector "${selector}" not found`);
            return;
        }

        // Get all child nodes
        const children = Array.from(titleElement.childNodes);

        // Clear the element
        titleElement.innerHTML = "";
        let charIndex = 0;

        // Process each child node
        children.forEach((child) => {
            if (child.nodeType === Node.TEXT_NODE) {
                // Handle text nodes
                const text = child.textContent || "";
                const span = document.createElement("span");

                text.split("").forEach((char) => {
                    const charSpan = document.createElement("span");
                    charSpan.textContent = char === " " ? "\u00A0" : char;
                    charSpan.style.opacity = "0";
                    charSpan.style.display = "inline-block";
                    charSpan.style.animation = `fadeInLetter ${duration}ms ease-out ${charIndex * delayPerLetter}ms forwards`;
                    charSpan.className = "letter-fade";
                    span.appendChild(charSpan);
                    charIndex++;
                });

                titleElement.appendChild(span);
            } else if (child.nodeType === Node.ELEMENT_NODE) {
                // Handle element nodes (like spans)
                const element = child as HTMLElement;
                const text = element.textContent || "";
                const wrapper = document.createElement("span");

                // Preserve original element's classes and attributes
                wrapper.className = element.className;
                if (element.style.cssText) {
                    wrapper.style.cssText = element.style.cssText;
                }

                // Handle SVG elements separately
                const svg = element.querySelector("svg");

                text.split("").forEach((char) => {
                    const charSpan = document.createElement("span");
                    charSpan.textContent = char === " " ? "\u00A0" : char;
                    charSpan.style.opacity = "0";
                    charSpan.style.display = "inline-block";
                    charSpan.style.animation = `fadeInLetter ${duration}ms ease-out ${charIndex * delayPerLetter}ms forwards`;
                    charSpan.className = "letter-fade highlight-letter";
                    wrapper.appendChild(charSpan);
                    charIndex++;
                });

                // Add SVG after letters if it exists
                if (svg) {
                    const svgClone = svg.cloneNode(true) as SVGElement;
                    svgClone.style.opacity = "0";
                    svgClone.style.animation = `fadeInSVG ${duration}ms ease-out ${charIndex * delayPerLetter + 200}ms forwards`;
                    wrapper.appendChild(svgClone);
                }

                titleElement.appendChild(wrapper);
            }
        });

        // Animate description after title
        const description = document.querySelector(
            ".approach-description",
        ) as HTMLElement;
        if (description) {
            description.style.opacity = "0";
            description.style.animation = `fadeInUp ${duration}ms ease-out ${charIndex * delayPerLetter + 400}ms forwards`;
        }
    }

    // Inject CSS animations if not already present
    function injectAnimationStyles(): void {
        if (!document.querySelector("style[data-letter-fade]")) {
            const style = document.createElement("style");
            style.setAttribute("data-letter-fade", "true");
            style.textContent = `
            @keyframes fadeInLetter {
                from {
                    opacity: 0;
                    transform: translateY(20px) rotateX(90deg);
                }
                50% {
                    opacity: 0.5;
                    transform: translateY(10px) rotateX(45deg);
                }
                to {
                    opacity: 1;
                    transform: translateY(0) rotateX(0deg);
                }
            }
            
            @keyframes fadeInSVG {
                from {
                    opacity: 0;
                    transform: scaleX(0);
                }
                to {
                    opacity: 0.6;
                    transform: scaleX(1);
                }
            }
            
            @keyframes fadeInUp {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
            
            .letter-fade {
                display: inline-block;
            }
            
            .highlight-letter {
                color: #F48C06 !important;
            }
        `;
            document.head.appendChild(style);
        }
    }

    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                entry.target.classList.add("animate-in");

                // Special handling for header animation
                if (entry.target.classList.contains("approach-header")) {
                    setTimeout(() => {
                        injectAnimationStyles();
                        animateTitle("#approach-title", 80, 600);
                    }, 200);
                }

                // Special handling for staggered step animations
                if (entry.target.classList.contains("approach-steps")) {
                    const steps =
                        entry.target.querySelectorAll(".approach-step");
                    steps.forEach((step, index) => {
                        setTimeout(() => {
                            step.classList.add("animate-in");
                        }, index * 150);
                    });
                }
            }
        });
    }, observerOptions);

    // Initialize animations when DOM is loaded
    document.addEventListener("DOMContentLoaded", () => {
        const elementsToAnimate = document.querySelectorAll(
            ".approach-header, .approach-steps, .approach-visual, .approach-stats, .approach-cta",
        );

        elementsToAnimate.forEach((el) => {
            observer.observe(el);
        });

        // Add floating animation to particles
        const particles = document.querySelectorAll('[class*="animate-float"]');
        particles.forEach((particle, index) => {
            const htmlParticle = particle as HTMLElement;
            htmlParticle.style.animationDelay = `${index * 0.5}s`;
        });
    });
</script>

<style>
    /* Base animation styles */
    .approach-header,
    .approach-steps,
    .approach-visual,
    .approach-stats,
    .approach-cta,
    .approach-step {
        opacity: 0;
        transform: translateY(40px);
        transition: all 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    /* Staggered delays for different sections */
    .approach-header {
        transition-delay: 0.1s;
    }
    .approach-visual {
        transition-delay: 0.3s;
    }
    .approach-stats {
        transition-delay: 0.4s;
    }
    .approach-cta {
        transition-delay: 0.5s;
    }

    /* Step-specific animations */
    .approach-step {
        transform: translateX(-30px) translateY(20px);
        transition-delay: 0s; /* Controlled by JavaScript */
    }

    /* Animate-in state */
    .animate-in {
        opacity: 1;
        transform: translateY(0) translateX(0);
    }

    /* Floating particle animations */
    @keyframes float {
        0%,
        100% {
            transform: translateY(0px) rotate(0deg);
        }
        33% {
            transform: translateY(-10px) rotate(120deg);
        }
        66% {
            transform: translateY(5px) rotate(240deg);
        }
    }

    @keyframes float-delayed {
        0%,
        100% {
            transform: translateY(0px) scale(1);
        }
        50% {
            transform: translateY(-15px) scale(1.2);
        }
    }

    @keyframes float-slow {
        0%,
        100% {
            transform: translateY(0px) translateX(0px);
        }
        25% {
            transform: translateY(-8px) translateX(4px);
        }
        50% {
            transform: translateY(-12px) translateX(-2px);
        }
        75% {
            transform: translateY(-6px) translateX(6px);
        }
    }

    .animate-float {
        animation: float 6s ease-in-out infinite;
    }

    .animate-float-delayed {
        animation: float-delayed 4s ease-in-out infinite;
    }

    .animate-float-slow {
        animation: float-slow 8s ease-in-out infinite;
    }

    /* Enhanced hover effects */
    .approach-step:hover {
        transform: translateY(-5px);
    }

    .approach-step .bg-gradient-to-r:hover {
        background: linear-gradient(
            to right,
            rgba(255, 255, 255, 0.1),
            rgba(255, 255, 255, 0.05)
        );
    }

    /* Enhanced Statistics Cards Animations */
    .approach-stats .group {
        position: relative;
        overflow: hidden;
    }

    .approach-stats .group::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(244, 140, 6, 0.1), transparent);
        transition: left 0.8s ease;
    }

    .approach-stats .group:hover::before {
        left: 100%;
    }

    /* Counter Animation for Statistics */
    @keyframes countUp {
        from {
            opacity: 0;
            transform: translateY(20px) scale(0.8);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .approach-stats .animate-in .text-4xl {
        animation: countUp 1s ease-out 0.5s both;
    }

    /* Pulse effect for icons */
    @keyframes iconPulse {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(244, 140, 6, 0.4);
        }
        50% {
            box-shadow: 0 0 0 10px rgba(244, 140, 6, 0);
        }
    }

    .approach-stats .group:hover .w-14 {
        animation: iconPulse 2s infinite;
    }

    /* Smooth gradient animations for step numbers */
    .approach-step .bg-gradient-to-br {
        background-size: 200% 200%;
        animation: gradient-shift 3s ease infinite;
    }

    @keyframes gradient-shift {
        0%,
        100% {
            background-position: 0% 50%;
        }
        50% {
            background-position: 100% 50%;
        }
    }

    /* Responsive adjustments */
    @media (max-width: 1279px) {
        .approach-step {
            transform: translateY(30px);
        }
    }

    /* Loading state improvements */
    .approach-header h2 {
        background: linear-gradient(135deg, #ffffff 0%, #99b0bb 100%);
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-size: 200% 200%;
        animation: text-shimmer 3s ease-in-out infinite;
    }

    @keyframes text-shimmer {
        0%,
        100% {
            background-position: 0% 50%;
        }
        50% {
            background-position: 100% 50%;
        }
    }

    .approach-header h2 span {
        -webkit-text-fill-color: #f48c06 !important;
        background: none !important;
        animation: none !important;
    }
</style>
