---
// Call Banner Component - Urgent CTA banner
import Button from "../ui/Button.astro";

export interface Props {
    message?: string;
    phoneNumber?: string;
    subtext?: string;
    buttonText?: string;
}

const {
    message = "Don't Waste Your Time, Call Today:",
    phoneNumber = "(555) 123-4567",
    subtext = "There are many myths passed on from the greater culture.",
    buttonText = "GET YOUR QUOTE",
} = Astro.props;
---

<section
    class="py-8 md:py-12 bg-gradient-to-br from-[#0a1931] to-[#1a2a4a]"
>
    <div class="max-w-7xl mx-auto">
        <div
            class="flex flex-col md:flex-row items-center justify-center gap-6 md:gap-8 px-[32px]"
        >
            <!-- Centered Content - Message and Phone -->
            <div class="text-center">
                <h3 id="call-banner-title" class="text-3xl md:text-5xl font-bold text-white mb-2 leading-tight">
                    Don't Waste Your Time, Call Today: <a
                        href={`tel:${phoneNumber.replace(/[^0-9+]/g, "")}`}
                        class="text-[#F48C06] hover:underline transition-all duration-300"
                    >
                        {phoneNumber}
                    </a>
                </h3>
                <p id="call-banner-subtext" class="text-white" style="font-size: 22px;">
                    {subtext}
                </p>
            </div>
        </div>
    </div>
</section>
