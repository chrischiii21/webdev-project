---
// Reviews Section with Horizontal Layout
import { getCollection } from 'astro:content';

// Get all reviews and sort by order
const allReviews = await getCollection('reviews');
const reviews = allReviews.sort((a, b) => a.data.order - b.data.order);
---

<section
  class="py-20 relative overflow-hidden"
  style="background: linear-gradient(135deg, var(--midnight-navy) 0%, color-mix(in srgb, var(--midnight-navy) 90%, var(--steel-pewter) 10%) 100%);"
>
  <div class="max-w-7xl mx-auto px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span
        class="font-semibold tracking-widest uppercase"
        style="color: var(--helios-orange); font-size: 16px;"
        id="success-stories-tag"
      >
        CLIENT SUCCESS STORIES
      </span>
      <h2 class="text-3xl md:text-5xl font-bold mb-6 text-white mt-4" id="success-stories-title">
        Real Results from <span style="color: var(--helios-orange);"
          >Real Contractors</span
        >
      </h2>
      <p class="max-w-6xl mx-auto leading-relaxed text-white" id="success-stories-desc" style="font-size: 22px;">
        See how HVAC and plumbing contractors transformed their businesses with
        BuildPro websites.
      </p>
    </div>

    <!-- Reviews Carousel -->
    <div
      class="bg-white rounded-3xl overflow-hidden shadow-2xl border border-gray-100 w-full"
      id="success-stories-carousel"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
        <!-- Image Section - Fixed with Auto Carousel -->
        <div
          class="relative h-80 md:h-auto overflow-hidden p-4 flex items-center justify-center bg-white"
        >
          <div class="relative w-full h-full">
            <img
              src="/images/img1.avif"
              alt="HVAC and plumbing work"
              class="image-carousel w-full h-full object-cover rounded-2xl transition-opacity duration-500 ease-in-out opacity-100"
              data-image="0"
            />
          </div>
        </div>

        <!-- Content Section - Carousel -->
        <div class="relative overflow-hidden">
          <div class="reviews-container">
            <div
              class="reviews-track flex transition-transform duration-500 ease-in-out"
            >
              {reviews.map((review) => (
                <div
                  class="review-slide flex-shrink-0 w-full p-8 lg:p-12 flex flex-col justify-between bg-white"
                >
                  <div>
                    <div class="flex items-center justify-between mb-6">
                      <div>
                        <span
                          class="inline-block px-3 py-1 rounded-full text-xs font-semibold tracking-wider uppercase mb-2"
                          style="background: color-mix(in srgb, var(--helios-orange) 15%, transparent); color: var(--helios-orange);"
                        >
                          Success Story
                        </span>
                        <h3
                          class="text-2xl font-bold"
                          style="color: var(--midnight-navy);"
                        >
                          {review.data.title}
                        </h3>
                      </div>
                      <div class="flex gap-1 text-xl">
                        <span style="color: var(--helios-orange);">★★★★★</span>
                      </div>
                    </div>

                    <p
                      class="text-lg leading-relaxed mb-6 font-medium text-[#0A1931]"
                    >
                      "{review.data.testimonial}"
                    </p>

                    <!-- Key Metrics -->
                    <div
                      class="grid grid-cols-2 gap-3 mb-6 pb-6 border-b border-gray-200"
                    >
                      <div>
                        <div
                          class="text-xl font-bold"
                          style="color: var(--helios-orange);"
                        >
                          {review.data.metric1Value}
                        </div>
                        <div class="text-base text-[#0A1931]">{review.data.metric1Label}</div>
                      </div>
                      <div>
                        <div
                          class="text-xl font-bold"
                          style="color: var(--helios-orange);"
                        >
                          {review.data.metric2Value}
                        </div>
                        <div class="text-base text-[#0A1931]">
                          {review.data.metric2Label}
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Client Info -->
                  <div class="flex items-center justify-between pb-12 md:pb-0">
                    <div class="flex items-center gap-3">
                      <div
                        class="w-12 h-12 rounded-full flex items-center justify-center font-bold text-white text-sm"
                        style="background: var(--helios-orange);"
                      >
                        {review.data.initials}
                      </div>
                      <div>
                        <div
                          class="font-bold text-base"
                          style="color: var(--midnight-navy);"
                        >
                          {review.data.clientName}
                        </div>
                        <div class="text-sm text-[#0A1931]">
                          {review.data.companyName}, {review.data.location}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Fixed Navigation Buttons - positioned below client info on mobile -->
          <div class="absolute bottom-2 md:bottom-8 lg:bottom-12 right-8 lg:right-12 z-10 flex gap-2">
            <button
              class="carousel-prev-inner w-10 h-10 rounded-full transition-all hover:scale-110 flex items-center justify-center cursor-pointer shadow-lg"
              style="background: var(--helios-orange);"
              aria-label="Previous review"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 19l-7-7 7-7"></path>
              </svg>
            </button>
            <button
              class="carousel-next-inner w-10 h-10 rounded-full transition-all hover:scale-110 flex items-center justify-center cursor-pointer shadow-lg"
              style="background: var(--helios-orange);"
              aria-label="Next review"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .reviews-container {
    position: relative;
    overflow: hidden;
  }

  .reviews-track {
    will-change: transform;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .review-slide {
    min-width: 100%;
    flex-shrink: 0;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const reviewsTrack = document.querySelector(
      ".reviews-track",
    ) as HTMLElement | null;
    const reviewSlides = document.querySelectorAll(".review-slide");
    const reviewsContainer = document.querySelector(
      ".reviews-container",
    ) as HTMLElement | null;
    const images = document.querySelectorAll(".image-carousel");

    if (!reviewsTrack) return;

    const originalSlides = Array.from(reviewSlides);
    const totalSlides = originalSlides.length;

    // Clone all slides and append to create infinite loop
    originalSlides.forEach((slide) => {
      const clone = slide.cloneNode(true) as HTMLElement;
      reviewsTrack.appendChild(clone);
    });

    let currentSlide = 0;
    let currentImageIndex = 0;
    const totalImages = images.length;
    let autoSlideInterval: ReturnType<typeof setInterval> | null = null;
    let isTransitioning = false;

    function updateCarousel(smooth = true) {
      if (!reviewsTrack) return;

      if (smooth) {
        reviewsTrack.style.transition =
          "transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94)";
      } else {
        reviewsTrack.style.transition = "none";
      }

      const translateX = -currentSlide * 100;
      reviewsTrack.style.transform = `translateX(${translateX}%)`;
    }

    function updateImages() {
      images.forEach((img, index) => {
        if (index === currentImageIndex) {
          img.classList.remove("opacity-0");
          img.classList.add("opacity-100");
        } else {
          img.classList.remove("opacity-100");
          img.classList.add("opacity-0");
        }
      });
    }

    function nextSlide() {
      if (isTransitioning) return;
      isTransitioning = true;

      currentSlide++;
      updateCarousel(true);

      // When we reach the cloned slides, reset to the beginning
      if (currentSlide >= totalSlides) {
        setTimeout(() => {
          currentSlide = 0;
          updateCarousel(false);
          isTransitioning = false;
        }, 600);
      } else {
        setTimeout(() => {
          isTransitioning = false;
        }, 600);
      }
    }

    function prevSlide() {
      if (isTransitioning) return;
      isTransitioning = true;

      if (currentSlide === 0) {
        // Jump to the last cloned slide instantly
        currentSlide = totalSlides;
        updateCarousel(false);

        setTimeout(() => {
          currentSlide--;
          updateCarousel(true);
          setTimeout(() => {
            isTransitioning = false;
          }, 600);
        }, 20);
      } else {
        currentSlide--;
        updateCarousel(true);
        setTimeout(() => {
          isTransitioning = false;
        }, 600);
      }
    }

    function nextImage() {
      currentImageIndex = (currentImageIndex + 1) % totalImages;
      updateImages();
    }

    function startAutoSlide() {
      autoSlideInterval = setInterval(nextSlide, 6000);
    }

    function stopAutoSlide() {
      if (autoSlideInterval) {
        clearInterval(autoSlideInterval);
      }
    }

    // Re-attach event listeners to all buttons (including cloned ones)
    function attachButtonListeners() {
      const allPrevBtns = document.querySelectorAll(".carousel-prev-inner");
      const allNextBtns = document.querySelectorAll(".carousel-next-inner");

      allPrevBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          prevSlide();
          stopAutoSlide();
          startAutoSlide();
        });
      });

      allNextBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          nextSlide();
          stopAutoSlide();
          startAutoSlide();
        });
      });
    }

    // Pause on hover
    if (reviewsContainer) {
      reviewsContainer.addEventListener("mouseenter", stopAutoSlide);
      reviewsContainer.addEventListener("mouseleave", startAutoSlide);
    }

    // Initialize
    attachButtonListeners();
    updateCarousel(false);
    updateImages();
    startAutoSlide();
    setInterval(nextImage, 5000);
  });
</script>
