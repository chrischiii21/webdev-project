---
// Trades Section with Hover Cards
import { getCollection } from 'astro:content';
import Button from '../ui/Button.astro';

// Get all trades and sort by order
const allTrades = await getCollection('trades');
const trades = allTrades.sort((a, b) => a.data.order - b.data.order);
---

<section class="py-20 relative overflow-hidden bg-parchment">
  <div class="max-w-7xl mx-auto px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span
        id="trades-tag"
        class="font-semibold tracking-widest uppercase"
        style="color: var(--helios-orange); font-size: 16px;"
      >
        TRADES WE SERVE
      </span>
      <h2
      id="trades-title"
        class="text-3xl md:text-5xl font-bold mb-6 mt-4"
        style="color: var(--midnight-navy);"
      >
        Our <span style="color: var(--helios-orange);">Expertise</span>
      </h2>
      <p id="trades-desc" class="max-w-3xl mx-auto leading-relaxed text-[#0A1931]" style="font-size: 22px;">
        We specialize in creating powerful digital solutions for contractors
        that convert visitors into customers.
      </p>
    </div>

    <!-- Trades Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full items-stretch">
      {trades.map((trade, index) => {
        const isHVAC = trade.data.slug === 'hvac';
        const textColor = isHVAC ? 'text-white' : 'text-white';
        const textOpacity = isHVAC ? 'text-white/80' : 'text-white/80';
        const textOpacity90 = isHVAC ? 'text-white/90' : 'text-white/90';
        
        return (
          <a
            id={`trade-${trade.data.slug}`}
            href={`/trades-we-serve/${trade.data.slug}`}
            class="group relative h-96 rounded-3xl overflow-hidden shadow-2xl cursor-pointer block transition-transform duration-300 hover:scale-[1.02]"
          >
            <!-- Image Background -->
            <img
              src={trade.data.image}
              alt={`${trade.data.name} technician`}
              class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
            />

            <!-- Overlay -->
            <div
              class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent transition-all duration-500"
              style={`--hover-color: ${trade.data.hoverColor};`}
              data-hover-color={trade.data.hoverColor}
            >
            </div>

            <!-- Content - Default State -->
            <div
              class="absolute inset-0 p-8 flex flex-col justify-end transition-all duration-500 group-hover:opacity-0"
            >
              <div class="text-white">
                <div class="font-semibold mb-3 opacity-80" style="font-size: 16px;">
                  {trade.data.name}
                </div>
                <h3 class="text-3xl font-bold">{trade.data.tagline}</h3>
              </div>
            </div>

            <!-- Content - Hover State -->
            <div
              class="absolute inset-0 p-8 flex flex-col justify-between opacity-0 transition-all duration-500 group-hover:opacity-100"
            >
              <div class={`font-semibold ${textOpacity}`} style="font-size: 16px;">{trade.data.name}</div>

              <div>
                <h3 class={`text-3xl font-bold ${textColor} mb-4`}>
                  {trade.data.hoverTitle}
                </h3>
                <p class={`${textOpacity90} text-base leading-relaxed mb-6 max-w-lg`}>
                  {trade.data.hoverDescription}
                </p>
                <Button
                  theme="light"
                  accentColor={trade.data.hoverColor === 'var(--helios-orange)' ? 'var(--midnight-navy)' : 'var(--helios-orange)'}
                >
                  Explore Templates
                </Button>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<script>
  // Handle dynamic hover colors for trade cards
  document.addEventListener('DOMContentLoaded', () => {
    const tradeCards = document.querySelectorAll('[id^="trade-"]');
    
    tradeCards.forEach(card => {
      const overlay = card.querySelector('[data-hover-color]') as HTMLElement | null;
      if (!overlay) return;
      
      const hoverColor = overlay.getAttribute('data-hover-color');
      
      card.addEventListener('mouseenter', () => {
        overlay.style.background = `linear-gradient(to top, ${hoverColor}, ${hoverColor}, ${hoverColor})`;
      });
      
      card.addEventListener('mouseleave', () => {
        overlay.style.background = 'linear-gradient(to top, rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.4), transparent)';
      });
    });
  });
</script>

<style>
  /* Smooth transitions */
  * {
    transition-property:
      transform, box-shadow, background-color, border-color, color, opacity;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>
