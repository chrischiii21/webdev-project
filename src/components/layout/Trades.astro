---
import { getCollection } from 'astro:content';
import TradeCard from '../ui/TradeCard.astro';

const trades = await getCollection('trades');
---

<section class="py-20 relative overflow-hidden bg-parchment">
  <div class="max-w-7xl mx-auto px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span
        id="trades-tag"
        class="text-sm font-semibold tracking-widest uppercase"
        style="color: var(--helios-orange);"
      >
        TRADES WE SERVE
      </span>
      <h2
      id="trades-title"
        class="text-4xl md:text-5xl font-bold mb-6 mt-4"
        style="color: var(--midnight-navy);"
      >
        Our <span style="color: var(--helios-orange);">Expertise</span>
      </h2>
      <p id="trades-desc" class="text-lg max-w-3xl mx-auto leading-relaxed text-[#0A1931]">
        We specialize in creating powerful digital solutions for contractors
        that convert visitors into customers.
      </p>
    </div>

    <!-- Trades Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 w-full items-stretch">
      {trades.map((trade) => (
        <TradeCard
          title={trade.data.title}
          shortTitle={trade.data.shortTitle}
          hoverDescription={trade.data.hoverDescription}
          description={trade.data.description}
          image={trade.data.image}
          overlayColor={trade.data.overlayColor}
          slug={trade.data.slug}
        />
      ))}
    </div>
  </div>
</section>
