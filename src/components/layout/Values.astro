---
// Values Component - Showcases company values and mission
import FeatureCard from "../ui/FeatureCard.astro";

export interface Props {
  title?: string;
  highlightWord?: string;
  description?: string;
  values?: Array<{
    title: string;
    description: string;
  }>;
}

const {
  title = "Why Choose Us",
  highlightWord = "Choose",
  description = "We're committed to delivering exceptional results through our core values and unwavering dedication to your success.",
  values = [
    {
      title: "Results-Driven",
      description:
        "We focus on measurable outcomes that directly impact your bottom line and business growth.",
    },
    {
      title: "Client-Focused",
      description:
        "Your success is our success. We build lasting partnerships based on trust and transparency.",
    },
    {
      title: "Reliable Support",
      description:
        "24/7 dedicated support team ready to help you succeed at every step of your journey.",
    },
    {
      title: "Fast & Efficient",
      description:
        "Quick turnaround times without compromising quality. We respect your time and deadlines.",
    },
  ],
} = Astro.props;

const titleParts = title.split(highlightWord);
---

<section class="py-20 bg-gradient-to-br from-[#0a1931] to-[#1a2a4a]">
  <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <span
        id="values-tag"
        class="text-sm font-semibold tracking-widest uppercase"
        style="color: var(--helios-orange);"
      >
        OUR VALUES
      </span>
      <h2
        id="values-title"
        class="text-4xl md:text-5xl font-bold text-white mb-6 mt-4"
      >
        {titleParts[0]}
        <span class="text-[#F48C06]">{highlightWord}</span>
        {titleParts[1]}
      </h2>
      <p id="values-desc" class="text-lg text-white max-w-3xl mx-auto">
        {description}
      </p>
    </div>

    <!-- Values Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        values.map((value, index) => (
          <FeatureCard
            id={`value-card-${index + 1}`}
            title={value.title}
            description={value.description}
            variant="value"
          />
        ))
      }
    </div>
  </div>
</section>
